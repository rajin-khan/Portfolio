---
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import SquareLines from "../components/square-lines.astro";
import "../assets/css/main.css";

const SITE_NAME = "Rajin Khan";
const DEFAULT_TITLE = "Rajin Khan | AI Engineer, Developer & Designer";
const DEFAULT_DESCRIPTION =
  "Portfolio and writing by Rajin Khan, an AI engineer and developer in Dhaka building thoughtful products across AI, computer vision, and the web.";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage = "/assets/images/rajins-banner-new.png",
  ogImageAlt = "Rajin Khan portfolio",
  type = "website",
  publishedTime,
  modifiedTime,
  noindex = false,
  structuredData = [],
} = Astro.props;

const siteUrl = Astro.site || new URL("https://rajinkhan.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const absoluteOgImage = new URL(ogImage, siteUrl);
const isHome = canonicalUrl.pathname === "/";
const pageTitle = isHome || String(title).includes(SITE_NAME)
  ? String(title)
  : `${title} | ${SITE_NAME}`;
const robots = noindex
  ? "noindex, nofollow, noarchive"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const extraSchemas = Array.isArray(structuredData) ? structuredData : [structuredData];
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl.href}#webpage`,
  url: canonicalUrl.href,
  name: pageTitle,
  description,
  inLanguage: "en",
  isPartOf: { "@id": `${siteUrl.href}#website` },
};
const isProjectDetail = /^\/projects\/[^/]+\/?$/.test(canonicalUrl.pathname);
const projectBreadcrumbSchema = isProjectDetail
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Projects",
          item: new URL("/projects/", siteUrl).href,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: String(title),
          item: canonicalUrl.href,
        },
      ],
    }
  : null;
const schemas = [projectBreadcrumbSchema, ...extraSchemas].filter(Boolean);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Rajin Khan" />
    <meta name="robots" content={robots} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/assets/images/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={type} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <title>{pageTitle}</title>

    <script is:inline>
      document.documentElement.classList.add("dark");
    </script>

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(pageSchema)}
    />
    {
      schemas.map((schema) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(schema)}
        />
      ))
    }
    <Fragment set:html={import.meta.env.HEADER_INJECT} />
  </head>
  <body class="antialiased bg-white dark:bg-neutral-950">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SquareLines />
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <script src="../assets/js/main.js"></script>
    <Fragment set:html={import.meta.env.FOOTER_INJECT} />
  </body>
</html>
