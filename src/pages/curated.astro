---
import { readdirSync } from "node:fs";
import { join } from "node:path";
import Layout from "../layouts/main.astro";

type IssueDetails = {
	summary: string;
	length: string;
	sections: Array<{ category: string; title: string }>;
};

const publicationHeadline = "Tech, design, whatever I like.";

const issueDetails: Record<number, IssueDetails> = {
	1: {
		summary:
			"The first dispatch: useful software, ambitious machines, strange research, good type, and a reminder to make things.",
		length: "29 pages",
		sections: [
			{
				category: "Think piece",
				title: "AGI was achieved last week, actually.",
			},
			{ category: "Hardware", title: "Is Neo the chosen one?" },
			{ category: "Software", title: "Networking, made stupidly simple." },
			{ category: "Research", title: "Talking with black boxes." },
			{ category: "Creative", title: "You need to create." },
			{ category: "Design", title: "Good fonts. Oh so free." },
			{ category: "Rajin's Lab", title: "Your note's a mess. Good." },
		],
	},
};

const defaultIssueDetails: IssueDetails = {
	summary:
		"A dispatch about technology, design, useful tools, and the ideas in between.",
	length: "PDF",
	sections: [],
};

function getIssueDate(issueNumber: number) {
	const date = new Date(2025, 11 + issueNumber - 1, 1);

	return {
		short: new Intl.DateTimeFormat("en", {
			month: "short",
			year: "2-digit",
		}).format(date),
		long: new Intl.DateTimeFormat("en", {
			month: "long",
			year: "numeric",
		}).format(date),
		datetime: `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(
			2,
			"0",
		)}`,
	};
}

let newsletterFiles: Array<{ filename: string; issueNumber: number }> = [];

try {
	const newslettersDir = join(process.cwd(), "public", "newsletters");
	newsletterFiles = readdirSync(newslettersDir)
		.filter((file) => file.endsWith(".pdf") && file.startsWith("curated-"))
		.map((file) => {
			const match = file.match(/curated-(\d+)\.pdf/);
			return match
				? { filename: file, issueNumber: Number.parseInt(match[1], 10) }
				: null;
		})
		.filter(
			(issue): issue is { filename: string; issueNumber: number } =>
				issue !== null,
		)
		.sort((a, b) => a.issueNumber - b.issueNumber);
} catch (error) {
	console.warn("Could not read newsletters directory:", error);
	newsletterFiles = [{ filename: "curated-001.pdf", issueNumber: 1 }];
}

const newsletters = newsletterFiles.map(({ filename, issueNumber }) => ({
	issueNumber,
	issueLabel: issueNumber.toString().padStart(3, "0"),
	date: getIssueDate(issueNumber),
	pdfPath: `/newsletters/${filename}`,
	previewPath: `/newsletters/${filename.replace(/\.pdf$/, "-preview.jpg")}`,
	details: issueDetails[issueNumber] ?? defaultIssueDetails,
}));

const latestIssue = newsletters[newsletters.length - 1] ?? {
	issueNumber: 1,
	issueLabel: "001",
	date: getIssueDate(1),
	pdfPath: "/newsletters/curated-001.pdf",
	previewPath: "/newsletters/curated-001-preview.jpg",
	details: issueDetails[1],
};
const nextIssueNumber = (latestIssue.issueNumber + 1)
	.toString()
	.padStart(3, "0");
---

<Layout
  title="Curated Newsletter"
  description="Curated is Rajin Khan's visual newsletter about technology, design, useful tools, and ideas worth keeping."
  ogImage={latestIssue.previewPath}
  ogImageAlt={`Cover of Curated issue ${latestIssue.issueLabel} by Rajin Khan`}
>
  <div class="curated-page" data-issue-viewer>
    <div class="light-streak-layer" aria-hidden="true">
      <div class="light-streak streak-1"></div>
      <div class="light-streak streak-2"></div>
      <div class="light-streak streak-3"></div>
      <div class="light-streak streak-4"></div>
      <div class="light-streak streak-5"></div>
      <div class="light-streak streak-6"></div>
    </div>

    <header class="curated-nav">
      <a href="/" class="home-link">
        <svg
          aria-hidden="true"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        <span>Home</span>
      </a>

      <span
        class="nav-issue"
        data-nav-issue
        aria-label={`Current issue ${latestIssue.issueLabel}`}
      >
        {latestIssue.issueLabel}
      </span>
    </header>

    <main class="curated-main">
      <section class="issue-stage" aria-labelledby="curated-title">
        <div class="issue-intro">
          <p class="eyebrow">A newsletter by Rajin Khan</p>
          <h1 id="curated-title">curated.</h1>
          <p class="issue-headline">{publicationHeadline}</p>
          <p class="issue-summary" data-issue-summary>{latestIssue.details.summary}</p>

          <div class="issue-actions">
            <a
              class="primary-action"
              data-read-link
              href={latestIssue.pdfPath}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span data-read-label>Read issue {latestIssue.issueLabel}</span>
              <svg
                aria-hidden="true"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 6l6 6-6 6"></path>
              </svg>
            </a>
            <a
              class="secondary-action"
              data-save-link
              href={latestIssue.pdfPath}
              download
            >
              <svg
                aria-hidden="true"
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 3v12M7 10l5 5 5-5M5 21h14"></path>
              </svg>
              <span>Save PDF</span>
            </a>
          </div>

          <dl class="issue-facts">
            <div>
              <dt>Issue</dt>
              <dd data-fact-issue>{latestIssue.issueLabel}</dd>
            </div>
            <div>
              <dt>Published</dt>
              <dd>
                <time data-fact-date datetime={latestIssue.date.datetime}
                  >{latestIssue.date.short}</time
                >
              </dd>
            </div>
            <div>
              <dt>Length</dt>
              <dd data-fact-length>{latestIssue.details.length}</dd>
            </div>
          </dl>
        </div>

        <div class="issue-preview">
          <a
            class="latest-cover"
            data-cover-link
            href={latestIssue.pdfPath}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Open Curated issue ${latestIssue.issueLabel} PDF`}
          >
            <span class="cover-index" data-cover-index aria-hidden="true"
              >Latest {latestIssue.issueLabel}</span
            >
            <img
              data-cover-image
              src={latestIssue.previewPath}
              alt={`Curated issue ${latestIssue.issueLabel} cover`}
              width="1200"
              height="1699"
              fetchpriority="high"
              decoding="async"
            />
            <span class="cover-open" aria-hidden="true">
              <span>Open issue</span>
              <svg
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 6l6 6-6 6"></path>
              </svg>
            </span>
          </a>

          {
            newsletters.length > 1 && (
              <div class="issue-picker" aria-label="Choose an issue">
                <button
                  type="button"
                  data-previous-issue
                  aria-label="Previous issue"
                  title="Previous issue"
                >
                  <svg
                    aria-hidden="true"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M19 12H5M11 18l-6-6 6-6"></path>
                  </svg>
                </button>
                <span class="issue-picker-label" data-picker-label aria-live="polite">
                  {latestIssue.issueLabel}
                </span>
                <button
                  type="button"
                  data-next-issue
                  aria-label="Next issue"
                  title="Next issue"
                  disabled
                >
                  <svg
                    aria-hidden="true"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14M13 6l6 6-6 6"></path>
                  </svg>
                </button>
              </div>
            )
          }
        </div>

        <aside class="issue-contents" aria-labelledby="contents-title">
          <div class="contents-heading">
            <p id="contents-title" data-contents-label>Inside {latestIssue.issueLabel}</p>
            <span data-story-count>{latestIssue.details.sections.length} stories</span>
          </div>

          <ol data-contents-list>
            {
              latestIssue.details.sections.map((section, index) => (
                <li>
                  <span class="story-index">
                    {(index + 1).toString().padStart(2, "0")}
                  </span>
                  <div>
                    <span class="story-category">{section.category}</span>
                    <span class="story-title">{section.title}</span>
                  </div>
                </li>
              ))
            }
          </ol>

        </aside>
      </section>

      <section class="archive" id="archive" aria-labelledby="archive-title">
        <div class="archive-heading">
          <div>
            <p class="eyebrow">Every issue</p>
            <h2 id="archive-title">The archive.</h2>
          </div>
          <p>
            {
              newsletters.length === 1
                ? "Had to start somewhere."
                : `${newsletters.length} issues. newest to oldest.`
            }
          </p>
        </div>

        <div class="issue-shelf" aria-label="Curated issue archive">
          <article class="archive-issue upcoming-issue">
            <div class="upcoming-cover" aria-hidden="true">
              <span class="upcoming-number">{nextIssueNumber}</span>
              <span class="upcoming-wordmark">curated.</span>
              <span class="upcoming-status">In the works</span>
            </div>
            <div class="archive-meta">
              <strong>Up next</strong>
              <span class="upcoming-release">When it's ready</span>
            </div>
          </article>

          {
            [...newsletters].reverse().map((issue) => (
              <a
                class="archive-issue"
                href={issue.pdfPath}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Open Curated issue ${issue.issueLabel} PDF`}
              >
                <div class="archive-cover">
                  <img
                    src={issue.previewPath}
                    alt=""
                    width="1200"
                    height="1699"
                    loading="lazy"
                    decoding="async"
                  />
                  <span aria-hidden="true">Read</span>
                </div>
                <div class="archive-meta">
                  <strong>Issue {issue.issueLabel}</strong>
                  <time datetime={issue.date.datetime}>{issue.date.long}</time>
                </div>
              </a>
            ))
          }
        </div>

      </section>

      <section class="archive-subscribe" aria-labelledby="curated-subscribe-title">
        <div class="archive-subscribe-inner">
          <div class="subscribe-copy">
            <p class="eyebrow">The next issue</p>
            <h3 id="curated-subscribe-title">Let it find you.</h3>
          </div>

          <form class="curated-subscribe-form" id="curated-subscribe-form">
            <label class="sr-only" for="curated-subscribe-email">Email address</label>
            <div class="subscribe-field">
              <input
                id="curated-subscribe-email"
                name="email"
                type="email"
                placeholder="Enter your email"
                autocomplete="email"
                inputmode="email"
                spellcheck="false"
                aria-describedby="curated-subscribe-status"
                required
              />
              <button type="submit">
                <span data-subscribe-label>SUBSCRIBE</span>
              </button>
            </div>
            <p
              class="curated-subscribe-status"
              id="curated-subscribe-status"
              role="status"
              aria-live="polite"
            ></p>
          </form>
        </div>
      </section>
    </main>

    <script
      id="curated-issue-data"
      type="application/json"
      is:inline
      set:html={JSON.stringify(newsletters)}
    ></script>
  </div>
</Layout>

<script>
  type CuratedIssue = {
    issueLabel: string;
    date: { short: string; datetime: string };
    pdfPath: string;
    previewPath: string;
    details: {
      summary: string;
      length: string;
      sections: Array<{ category: string; title: string }>;
    };
  };

  const viewer = document.querySelector<HTMLElement>("[data-issue-viewer]");
  const issueData = document.querySelector<HTMLScriptElement>("#curated-issue-data");

  if (viewer && issueData) {
    const issues = JSON.parse(issueData.textContent ?? "[]") as CuratedIssue[];
    let activeIndex = Math.max(issues.length - 1, 0);

    const navIssue = viewer.querySelector<HTMLElement>("[data-nav-issue]");
    const summary = viewer.querySelector<HTMLElement>("[data-issue-summary]");
    const readLink = viewer.querySelector<HTMLAnchorElement>("[data-read-link]");
    const readLabel = viewer.querySelector<HTMLElement>("[data-read-label]");
    const saveLink = viewer.querySelector<HTMLAnchorElement>("[data-save-link]");
    const factIssue = viewer.querySelector<HTMLElement>("[data-fact-issue]");
    const factDate = viewer.querySelector<HTMLTimeElement>("[data-fact-date]");
    const factLength = viewer.querySelector<HTMLElement>("[data-fact-length]");
    const coverLink = viewer.querySelector<HTMLAnchorElement>("[data-cover-link]");
    const coverIndex = viewer.querySelector<HTMLElement>("[data-cover-index]");
    const coverImage = viewer.querySelector<HTMLImageElement>("[data-cover-image]");
    const pickerLabel = viewer.querySelector<HTMLElement>("[data-picker-label]");
    const previousButton = viewer.querySelector<HTMLButtonElement>("[data-previous-issue]");
    const nextButton = viewer.querySelector<HTMLButtonElement>("[data-next-issue]");
    const contentsLabel = viewer.querySelector<HTMLElement>("[data-contents-label]");
    const storyCount = viewer.querySelector<HTMLElement>("[data-story-count]");
    const contentsList = viewer.querySelector<HTMLOListElement>("[data-contents-list]");
    const storyTemplate = contentsList?.querySelector("li")?.cloneNode(true) as HTMLElement | undefined;

    const renderIssue = (index: number) => {
      const issue = issues[index];
      if (!issue) return;

      activeIndex = index;

      if (navIssue) {
        navIssue.textContent = issue.issueLabel;
        navIssue.setAttribute("aria-label", `Current issue ${issue.issueLabel}`);
      }
      if (summary) summary.textContent = issue.details.summary;
      if (readLink) readLink.href = issue.pdfPath;
      if (readLabel) readLabel.textContent = `Read issue ${issue.issueLabel}`;
      if (saveLink) saveLink.href = issue.pdfPath;
      if (factIssue) factIssue.textContent = issue.issueLabel;
      if (factDate) {
        factDate.textContent = issue.date.short;
        factDate.dateTime = issue.date.datetime;
      }
      if (factLength) factLength.textContent = issue.details.length;
      if (coverIndex) {
        const issueStatus = activeIndex === issues.length - 1 ? "Latest" : "Issue";
        coverIndex.textContent = `${issueStatus} ${issue.issueLabel}`;
      }
      if (coverLink) {
        coverLink.href = issue.pdfPath;
        coverLink.setAttribute("aria-label", `Open Curated issue ${issue.issueLabel} PDF`);
      }
      if (coverImage) {
        coverImage.src = issue.previewPath;
        coverImage.alt = `Curated issue ${issue.issueLabel} cover`;
      }
      if (pickerLabel) pickerLabel.textContent = issue.issueLabel;
      if (contentsLabel) contentsLabel.textContent = `Inside ${issue.issueLabel}`;
      if (storyCount) {
        const count = issue.details.sections.length;
        storyCount.textContent = `${count} ${count === 1 ? "story" : "stories"}`;
      }

      if (contentsList && storyTemplate) {
        contentsList.replaceChildren(
          ...issue.details.sections.map((section, storyIndex) => {
            const story = storyTemplate.cloneNode(true) as HTMLElement;
            const indexLabel = story.querySelector<HTMLElement>(".story-index");
            const category = story.querySelector<HTMLElement>(".story-category");
            const title = story.querySelector<HTMLElement>(".story-title");

            if (indexLabel) indexLabel.textContent = String(storyIndex + 1).padStart(2, "0");
            if (category) category.textContent = section.category;
            if (title) title.textContent = section.title;
            return story;
          })
        );
      }

      if (previousButton) previousButton.disabled = activeIndex === 0;
      if (nextButton) nextButton.disabled = activeIndex === issues.length - 1;
    };

    previousButton?.addEventListener("click", () => renderIssue(activeIndex - 1));
    nextButton?.addEventListener("click", () => renderIssue(activeIndex + 1));
  }
</script>

<script>
  const subscribeForm = document.querySelector<HTMLFormElement>(
    "#curated-subscribe-form"
  );

  if (subscribeForm && subscribeForm.dataset.bound !== "true") {
    subscribeForm.dataset.bound = "true";

    const emailInput = subscribeForm.querySelector<HTMLInputElement>(
      "#curated-subscribe-email"
    );
    const submitButton = subscribeForm.querySelector<HTMLButtonElement>(
      'button[type="submit"]'
    );
    const buttonLabel = subscribeForm.querySelector<HTMLElement>(
      "[data-subscribe-label]"
    );
    const status = subscribeForm.querySelector<HTMLElement>(
      "#curated-subscribe-status"
    );

    subscribeForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!emailInput || !submitButton || !buttonLabel || !status) return;

      if (!emailInput.reportValidity()) {
        status.textContent = "A valid email works best.";
        status.dataset.state = "error";
        return;
      }

      submitButton.disabled = true;
      submitButton.setAttribute("aria-busy", "true");
      buttonLabel.textContent = "Joining";
      status.textContent = "Passing your address to A.R.I.A...";
      status.dataset.state = "pending";

      try {
        const response = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email: emailInput.value.trim() }),
        });
        const data = response.headers.get("content-type")?.includes("application/json")
          ? ((await response.json()) as { error?: string })
          : {};

        if (!response.ok) {
          throw new Error(data.error || "Something went wrong. Try again.");
        }

        emailInput.value = "";
        buttonLabel.textContent = "Joined";
        status.textContent = "You're in. The next issue will find you.";
        status.dataset.state = "success";

        window.setTimeout(() => {
          buttonLabel.textContent = "Subscribe";
          submitButton.disabled = false;
          submitButton.removeAttribute("aria-busy");
        }, 2500);
      } catch (error) {
        buttonLabel.textContent = "Subscribe";
        submitButton.disabled = false;
        submitButton.removeAttribute("aria-busy");
        status.textContent =
          error instanceof Error ? error.message : "Couldn't subscribe just now.";
        status.dataset.state = "error";
      }
    });
  }
</script>

<style>
  @font-face {
    font-family: "La Belle Aurore";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/assets/fonts/la-belle-aurore-latin.woff2") format("woff2");
  }

  @font-face {
    font-family: "Instrument Serif";
    font-style: italic;
    font-weight: 400;
    font-display: swap;
    src: url("/assets/fonts/instrument-serif-italic-latin.woff2") format("woff2");
  }

  @font-face {
    font-family: "Satoshi";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/assets/fonts/satoshi-regular.woff") format("woff");
  }

  :global(header#header),
  :global(body > div.relative.w-full.h-20[aria-hidden="true"]),
  :global(.square-lines) {
    display: none !important;
  }

  :global(body) {
    overflow-x: hidden;
    background: #080808 !important;
  }

  :global(#main-content) {
    outline: none;
  }

  :global(body > footer) {
    margin-top: 0 !important;
  }

  .curated-page {
    --ink: #080808;
    --paper: #f3f2ed;
    --muted: #9c9b96;
    --line: rgba(255, 255, 255, 0.14);
    --rust: #c67a55;
    --sage: #a9b99c;
    min-height: 100svh;
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
    color: var(--paper);
    background-color: var(--ink);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 96px 96px;
    font-family:
      "Satoshi",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-weight: 500;
  }

  .curated-nav {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 76px;
    width: 100%;
    padding: 0 clamp(20px, 3vw, 48px);
    border-bottom: 1px solid var(--line);
    background: rgba(8, 8, 8, 0.92);
    backdrop-filter: blur(16px);
  }

  .home-link,
  .primary-action,
  .secondary-action,
  .latest-cover,
  .archive-issue {
    text-decoration: none;
  }

  .home-link {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: #b8b7b2;
    font-size: 13px;
    transition: color 180ms ease;
  }

  .home-link svg {
    transition: transform 180ms ease;
  }

  .home-link:hover {
    color: var(--paper);
  }

  .home-link:hover svg {
    transform: translateX(-3px);
  }

  .nav-issue {
    justify-self: end;
    color: var(--paper);
    font-size: 11px;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0;
  }

  .light-streak-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .light-streak {
    position: absolute;
    width: 3px;
    height: 200%;
    opacity: 0;
    background: linear-gradient(
      30deg,
      transparent,
      rgba(59, 130, 246, 0.6),
      rgba(34, 197, 94, 0.6),
      rgba(250, 204, 21, 0.6),
      rgba(249, 115, 22, 0.6),
      transparent
    );
    filter: blur(8px);
    transform-origin: center center;
    animation: streakMove 8s ease-in-out infinite;
    z-index: 0;
    pointer-events: none;
  }

  .streak-1 {
    left: 10%;
    animation-delay: 0s;
  }

  .streak-2 {
    left: 35%;
    animation-delay: 2s;
    width: 4px;
    background: linear-gradient(
      30deg,
      transparent,
      rgba(147, 51, 234, 0.6),
      rgba(59, 130, 246, 0.6),
      rgba(34, 197, 94, 0.6),
      rgba(250, 204, 21, 0.6),
      transparent
    );
  }

  .streak-3 {
    left: 60%;
    animation-delay: 4s;
    width: 2px;
  }

  .streak-4 {
    right: 15%;
    animation-delay: 1.5s;
    width: 3px;
    background: linear-gradient(
      30deg,
      transparent,
      rgba(249, 115, 22, 0.6),
      rgba(239, 68, 68, 0.6),
      transparent
    );
  }

  .streak-5 {
    left: 5%;
    animation-delay: 3s;
    width: 2.5px;
    background: linear-gradient(
      30deg,
      transparent,
      rgba(59, 130, 246, 0.5),
