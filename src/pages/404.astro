---
import Layout from "../layouts/main.astro";
---

<Layout
  title="Page not found"
  description="That page could not be found. Head back to Rajin Khan's portfolio."
  noindex={true}
>
  <section class="not-found" aria-labelledby="not-found-title">
    <div class="not-found__frame animate-in">
      <div class="error-scene">
        <span class="error-digit" aria-hidden="true">4</span>

        <div
          class="zero-slot"
          data-format="square"
          style="--sticker-aspect: 736 / 723;"
        >
          <p class="zero-slot__aside" aria-hidden="true">
            i swear there was a page here.
          </p>

          <article
            class="lost-sticker is-ready"
            id="lost-sticker"
            aria-label="Undeliverable page sticker"
          >
            <div class="lost-sticker__inner">
              <div class="lost-sticker__face lost-sticker__front">
                <img
                  id="lost-sticker-image"
                  src="/assets/images/stickers/curated/sticker-056.jpg"
                  alt=""
                  width="736"
                  height="723"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  draggable="false"
                />

                <span class="flip-cue" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"></path>
                    <path d="M21 3v5h-5"></path>
                  </svg>
                </span>

                <button
                  class="lost-sticker__trigger"
                  id="turn-sticker-over"
                  type="button"
                  aria-label="Turn the lost sticker over"
                  aria-controls="sticker-back"
                  aria-expanded="false"
                  title="Read the back"
                >
                </button>
              </div>

              <div
                class="lost-sticker__face lost-sticker__back"
                id="sticker-back"
                aria-hidden="true"
                inert
              >
                <img
                  class="note-doodle"
                  src="/assets/images/stickers/doodles/doodle-1.png"
                  alt=""
                  width="360"
                  height="360"
                  loading="eager"
                  decoding="async"
                  aria-hidden="true"
                />

                <p class="note-copy" id="aria-note">
                  you are not lost.<br />
                  this page is.
                </p>

                <p class="note-meta" aria-hidden="true">
                  <span>~ A.R.I.A.</span>
                  <time id="note-date" datetime="2026-07-19">19.07.26</time>
                </p>

                <button
                  class="lost-sticker__trigger flip-back"
                  id="turn-sticker-back"
                  type="button"
                  aria-label="Turn the sticker back over"
                  title="Show the front"
                >
                  <span class="flip-back__cue" aria-hidden="true">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M3 12a9 9 0 1 0 9-9c-2.52 0-4.93 1-6.74 2.74L3 8"></path>
                      <path d="M3 3v5h5"></path>
                    </svg>
                  </span>
                </button>
              </div>
            </div>
          </article>
        </div>

        <span class="error-digit" aria-hidden="true">4</span>
      </div>

      <div class="not-found__copy">
        <h1 id="not-found-title">
          <span class="sr-only">Error 404: </span>
          This sticker slipped off the board.
        </h1>
        <p>
          A.R.I.A. left you a little message on the back, though.
        </p>
      </div>

      <div class="not-found__actions">
        <a class="escape-link escape-link--primary" href="/">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          <span>Back home</span>
        </a>

        <a
          class="escape-link escape-link--aria"
          href="https://aria-lite.vercel.app/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M8 12h.01"></path>
            <path d="M12 12h.01"></path>
            <path d="M16 12h.01"></path>
            <path d="M21 12c0 4.42-4.03 8-9 8a10 10 0 0 1-4.26-.95L3 20l1.4-3.72A7.25 7.25 0 0 1 3 12c0-4.42 4.03-8 9-8s9 3.58 9 8Z"></path>
          </svg>
          <span>Continue talking to A.R.I.A.</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import stickerCatalog from "../data/stickers.json";

  type StickerFormat = "portrait" | "square" | "landscape";

  const sticker = document.querySelector<HTMLElement>("#lost-sticker");
  const stickerImage = document.querySelector<HTMLImageElement>("#lost-sticker-image");
  const zeroSlot = document.querySelector<HTMLElement>(".zero-slot");
  const openButton = document.querySelector<HTMLButtonElement>("#turn-sticker-over");
  const closeButton = document.querySelector<HTMLButtonElement>("#turn-sticker-back");
  const backFace = document.querySelector<HTMLElement>("#sticker-back");
  const noteCopy = document.querySelector<HTMLElement>("#aria-note");
  const noteDate = document.querySelector<HTMLTimeElement>("#note-date");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const finePointer = window.matchMedia("(pointer: fine)");
  const stickerMemoryKey = "rajin-404-last-sticker";
  const noteMemoryKey = "rajin-404-last-note";
  const eligibleStickers = stickerCatalog.filter(
    ({ aspectRatio }) => aspectRatio <= 2,
  );

  const ariaNotes = [
    "you are not lost.\nthis page is.",
    "i checked under\nevery pixel. nada.",
    "this page left\nfor snacks. iconic.",
    "wrong address.\nexcellent visitor.",
    "you found me.\nthe page? less so.",
    "the server shrugged.\ni brought a sticker.",
    "this page is hiding.\nvery committed.",
    "tiny detour.\nstill very glad\nyou're here.",
    "i checked the cache.\nit checked me back.",
    "nothing here.\njust me waving.",
    "the url took\na tiny wrong turn.",
    "404, but you look\nlovely today.",
    "this page vanished.\nsuspiciously cute.",
    "i asked nicely.\nthe internet said no.",
    "one missing page.\none excellent outfit.",
    "the link is broken.\nyou are doing great.",
    "this page followed\na shiny link.",
    "no page. just vibes.\nand a sticker.",
    "plot twist:\nsecret note found.",
    "i lost the page.\nplease accept this\nsmall apology.",
    "page is on a break.\nhonestly, relatable.",
    "bad url.\ngood company.",
    "the page ghosted us.\nrude, but cinematic.",
    "i ran the numbers.\nstill 404. dramatic.",
    "boop.\nwrong little corner\nof the internet.",
    "i found zero pages\nand one lovely human.",
    "the page is missing.\nyour timing is perfect.",
    "congrats!\nyou found the soft\nside of a 404.",
    "this was not the plan.\nbut hi. i like you.",
    "even robots get lost.\nwe look cute doing it.",
  ];

  let flipped = false;
  let tiltFrame = 0;

  function randomIndex(length: number) {
    if (length <= 1) return 0;

    const randomValue = new Uint32Array(1);
    window.crypto.getRandomValues(randomValue);
    return randomValue[0] % length;
  }

  function stickerFormat(aspectRatio: number): StickerFormat {
    if (aspectRatio < 0.86) return "portrait";
    if (aspectRatio > 1.18) return "landscape";
    return "square";
  }

  function selectRandomSticker() {
    let lastStickerId = "";

    try {
      lastStickerId = window.sessionStorage.getItem(stickerMemoryKey) || "";
    } catch {
      lastStickerId = "";
    }

    const choices = eligibleStickers.filter(({ id }) => id !== lastStickerId);
    const formats: StickerFormat[] = ["portrait", "square", "landscape"];
    const populatedFormats = formats.filter((format) =>
      choices.some(({ aspectRatio }) => stickerFormat(aspectRatio) === format),
    );
    const selectedFormat = populatedFormats[randomIndex(populatedFormats.length)];
    const formatChoices = choices.filter(
      ({ aspectRatio }) => stickerFormat(aspectRatio) === selectedFormat,
    );
    const selectedSticker = formatChoices[randomIndex(formatChoices.length)];

    try {
      window.sessionStorage.setItem(stickerMemoryKey, selectedSticker.id);
    } catch {
      // Random selection still works when storage is unavailable.
    }

    return selectedSticker;
  }

  function setRandomSticker() {
    if (!sticker || !stickerImage || !zeroSlot) return;

    const selectedSticker = selectRandomSticker();
    const format = stickerFormat(selectedSticker.aspectRatio);
    const revealSticker = () => {
      window.requestAnimationFrame(() => sticker.classList.add("is-ready"));
    };

    sticker.classList.remove("is-ready");
    sticker.dataset.stickerId = selectedSticker.id;
    sticker.setAttribute(
      "aria-label",
      `Undeliverable page sticker, ${selectedSticker.id.replace("sticker-", "number ")}`,
    );
    zeroSlot.dataset.format = format;
    zeroSlot.style.setProperty(
      "--sticker-aspect",
      `${selectedSticker.width} / ${selectedSticker.height}`,
    );
    stickerImage.addEventListener("load", revealSticker, { once: true });
    stickerImage.src = selectedSticker.src;
    stickerImage.width = selectedSticker.width;
    stickerImage.height = selectedSticker.height;

    if (stickerImage.complete) revealSticker();
  }

  function setRandomNote() {
    if (!noteCopy) return;

    let lastNote = "";

    try {
      lastNote = window.sessionStorage.getItem(noteMemoryKey) || "";
    } catch {
      lastNote = "";
    }

    const choices = ariaNotes.filter((note) => note !== lastNote);
    const selectedNote = choices[randomIndex(choices.length)];
    noteCopy.textContent = selectedNote;
    noteCopy.setAttribute(
      "aria-label",
      `${selectedNote.replaceAll("\n", " ")}, from A.R.I.A.`,
    );

    try {
      window.sessionStorage.setItem(noteMemoryKey, selectedNote);
    } catch {
      // The note still randomizes when storage is unavailable.
    }
  }

  if (noteDate) {
    const now = new Date();
    const day = String(now.getDate()).padStart(2, "0");
    const month = String(now.getMonth() + 1).padStart(2, "0");
    const year = String(now.getFullYear()).slice(-2);
    noteDate.dateTime = now.toISOString().slice(0, 10);
    noteDate.textContent = `${day}.${month}.${year}`;
  }

  function resetTilt() {
    if (!sticker) return;
    sticker.style.setProperty("--tilt-x", "0deg");
    sticker.style.setProperty("--tilt-y", "0deg");
    sticker.style.setProperty("--lift-x", "0px");
    sticker.style.setProperty("--lift-y", "0px");
  }

  function setFlipped(nextFlipped: boolean, restoreFocus = false) {
    if (!sticker || !openButton || !closeButton || !backFace) return;

    flipped = nextFlipped;
    sticker.classList.toggle("is-flipped", flipped);
    openButton.disabled = flipped;
    openButton.setAttribute("aria-expanded", String(flipped));
    backFace.inert = !flipped;
    backFace.setAttribute("aria-hidden", String(!flipped));
    resetTilt();

    const focusDelay = reducedMotion.matches ? 0 : 470;
    window.setTimeout(() => {
      if (flipped) {
        closeButton.focus({ preventScroll: true });
      } else if (restoreFocus) {
        openButton.focus({ preventScroll: true });
      }
    }, focusDelay);
  }

  openButton?.addEventListener("click", () => setFlipped(true));
  closeButton?.addEventListener("click", () => setFlipped(false, true));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && flipped) {
      setFlipped(false, true);
    }
  });

  sticker?.addEventListener("pointermove", (event) => {
    if (!sticker || flipped || reducedMotion.matches || !finePointer.matches) return;

    const bounds = sticker.getBoundingClientRect();
    const normalizedX = (event.clientX - bounds.left) / bounds.width - 0.5;
    const normalizedY = (event.clientY - bounds.top) / bounds.height - 0.5;

    window.cancelAnimationFrame(tiltFrame);
    tiltFrame = window.requestAnimationFrame(() => {
      sticker.style.setProperty("--tilt-x", `${normalizedY * -7}deg`);
      sticker.style.setProperty("--tilt-y", `${normalizedX * 9}deg`);
      sticker.style.setProperty("--lift-x", `${normalizedX * 7}px`);
      sticker.style.setProperty("--lift-y", `${normalizedY * 5}px`);
    });
  });

  sticker?.addEventListener("pointerleave", resetTilt);
  setRandomSticker();
  setRandomNote();
</script>

<style>
  @font-face {
    font-family: "La Belle Aurore";
    src: url("/assets/fonts/la-belle-aurore-latin.woff2") format("woff2");
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }

  .not-found {
    --ink: rgb(245 245 245);
    --muted: rgb(163 163 163);
    --line: rgb(64 64 64);
    --card-height: 7rem;
    --portrait-width: 6.5rem;
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: calc(100svh - 5rem);
    place-items: center;
    overflow: hidden;
    padding: 1.75rem 1rem 2.5rem;
    color: var(--ink);
    font-family: inherit;
  }

  .not-found__frame {
    display: flex;
    width: min(100%, 64rem);
    flex-direction: column;
    align-items: center;
  }

  .error-scene {
    display: grid;
    min-height: 11.75rem;
    width: 100%;
    grid-template-columns: repeat(3, max-content);
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    perspective: 1100px;
  }

  .error-digit {
    color: transparent;
    font-size: 4rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    line-height: 0.74;
    letter-spacing: 0;
    -webkit-text-stroke: 1px rgb(229 229 229 / 0.4);
    text-shadow: 0 0 24px rgb(255 255 255 / 0.025);
    transition:
      color 300ms ease,
      -webkit-text-stroke-color 300ms ease;
    user-select: none;
  }

  .error-scene:has(.lost-sticker:hover) .error-digit,
  .error-scene:has(.lost-sticker:focus-within) .error-digit {
    color: rgb(245 245 245 / 0.055);
    -webkit-text-stroke-color: rgb(245 245 245 / 0.68);
  }

  .zero-slot {
    --note-meta-bottom: clamp(0.7rem, 4%, 0.85rem);
    --note-meta-right: clamp(1rem, 5%, 1.45rem);
    position: relative;
    display: grid;
    width: auto;
    height: var(--card-height);
    aspect-ratio: var(--sticker-aspect);
    place-items: center;
  }

  .zero-slot[data-format="portrait"] {
    --note-meta-bottom: 2.35rem;
    --note-meta-right: 0.6rem;
    width: var(--portrait-width);
    height: auto;
  }

  .zero-slot:not([data-format="landscape"]) {
    --note-meta-bottom: clamp(2rem, 17%, 2.8rem);
    --note-meta-right: clamp(0.65rem, 5%, 1rem);
  }

  .zero-slot::before {
    position: absolute;
    inset: -1.15rem -0.6rem;
    border: 1px dashed rgb(82 82 82 / 0.76);
    border-radius: 50%;
    content: "";
    pointer-events: none;
    transform: rotate(-3deg);
  }

  .zero-slot::after {
    position: absolute;
    inset: -0.55rem 0.2rem;
    border: 1px solid rgb(38 38 38);
    border-radius: 50%;
    content: "";
    pointer-events: none;
    transform: rotate(2deg);
  }

  .zero-slot__aside {
    position: absolute;
    z-index: 4;
    top: -1.9rem;
    left: 50%;
    width: max-content;
    margin: 0;
    color: rgb(212 212 212 / 0.76);
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 0.92rem;
    line-height: 1;
    letter-spacing: 0;
    pointer-events: none;
    transform: translateX(-50%) rotate(-5deg);
  }

  .lost-sticker {
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    --lift-x: 0px;
    --lift-y: 0px;
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    aspect-ratio: inherit;
    transform:
      translate3d(var(--lift-x), var(--lift-y), 0)
      rotateX(var(--tilt-x))
      rotateY(var(--tilt-y))
      rotate(-1.25deg);
    transform-style: preserve-3d;
    transition: transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }

  .lost-sticker__inner {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transition: transform 680ms cubic-bezier(0.2, 0.82, 0.25, 1);
  }

  .lost-sticker.is-flipped .lost-sticker__inner {
    transform: rotateY(180deg);
  }

  .lost-sticker__face {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: 0.48rem;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    box-shadow:
      0 2rem 4.5rem rgb(0 0 0 / 0.58),
      0 0 0 1px rgb(255 255 255 / 0.08),
      0 0 0 0.28rem rgb(20 20 20);
    transform-style: preserve-3d;
  }

  .lost-sticker__front {
    background: rgb(10 10 10);
    transform: rotateY(0deg) translateZ(1px);
  }

  .lost-sticker__front::after {
    position: absolute;
    inset: 0;
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: inherit;
    content: "";
    pointer-events: none;
  }

  .lost-sticker__front img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(0.99);
    transition:
      filter 300ms ease,
      opacity 240ms ease,
      transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .lost-sticker.is-ready .lost-sticker__front img {
    opacity: 1;
    transform: scale(1);
  }

  .lost-sticker:hover .lost-sticker__front img,
  .lost-sticker:focus-within .lost-sticker__front img {
    filter: brightness(1.06) saturate(1.04);
    transform: scale(1.025);
  }

  .lost-sticker__trigger {
    position: absolute;
    z-index: 5;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    border-radius: inherit;
    background: transparent;
    cursor: pointer;
  }

  .lost-sticker__trigger:disabled {
    pointer-events: none;
  }

  .flip-cue {
    position: absolute;
    z-index: 3;
    right: 0.7rem;
    bottom: 0.7rem;
    display: grid;
    width: 1.8rem;
    height: 1.8rem;
    place-items: center;
    border: 1px solid rgb(255 255 255 / 0.24);
    border-radius: 50%;
    background: rgb(10 10 10 / 0.82);
    color: rgb(229 229 229);
    pointer-events: none;
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .flip-cue svg,
  .flip-back__cue svg,
  .escape-link svg {
    width: 1rem;
    height: 1rem;
  }

  .lost-sticker:hover .flip-cue,
  .lost-sticker:focus-within .flip-cue {
    border-color: rgb(255 255 255 / 0.46);
    background: rgb(23 23 23 / 0.94);
    color: rgb(250 250 250);
    transform: rotate(14deg) scale(1.04);
  }

  .lost-sticker__back {
    background:
      linear-gradient(
        90deg,
        transparent 0 13%,
        rgb(224 116 116 / 0.34) 13.25%,
        transparent 13.7%
      ),
      repeating-linear-gradient(
        0deg,
        rgb(252 248 232) 0 1.62rem,
        rgb(123 166 203 / 0.28) 1.66rem,
        rgb(252 248 232) 1.72rem
      );
    color: rgb(44 41 36);
    transform: rotateY(180deg) translateZ(1px);
  }

  .note-doodle {
    position: absolute;
    top: 0.65rem;
    left: 0.8rem;
    width: 2.35rem;
    height: 2.35rem;
    object-fit: contain;
    opacity: 0.58;
    pointer-events: none;
    transform: rotate(-11deg);
  }

  .note-copy {
    position: absolute;
    top: 47%;
    left: 50%;
    width: 74%;
    margin: 0;
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 1.2rem;
    line-height: 1.2;
    letter-spacing: 0;
    pointer-events: none;
    text-align: center;
    text-wrap: balance;
    transform: translate(-50%, -50%) rotate(-2deg);
    white-space: pre-line;
  }

  .note-meta {
    position: absolute;
    right: var(--note-meta-right);
    bottom: var(--note-meta-bottom);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.1rem;
    margin: 0;
    color: rgb(44 41 36 / 0.62);
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 0.62rem;
    line-height: 1.12;
    letter-spacing: 0;
    transform: rotate(-2deg);
  }

  .flip-back {
    color: rgb(44 41 36 / 0.72);
  }

  .flip-back__cue {
    position: absolute;
    top: 0.65rem;
    right: 0.65rem;
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    border: 1px solid rgb(44 41 36 / 0.2);
    border-radius: 50%;
    background: rgb(252 248 232 / 0.78);
    pointer-events: none;
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .flip-back:hover .flip-back__cue,
  .flip-back:focus-visible .flip-back__cue {
    background: rgb(252 248 232);
    transform: rotate(-15deg);
  }

  .zero-slot[data-format="portrait"] .note-copy {
    top: 42%;
    width: 82%;
    font-size: 1.1rem;
  }

  .zero-slot[data-format="portrait"] .note-meta {
    font-size: 0.58rem;
  }

  .zero-slot[data-format="square"] .note-copy {
    top: 40%;
    width: 82%;
    font-size: 1.2rem;
  }

  .zero-slot[data-format="square"] .note-meta {
    font-size: 0.62rem;
  }

  .not-found__copy {
    max-width: 34rem;
    margin-top: 0.75rem;
    text-align: center;
  }

  .not-found__copy h1 {
    margin: 0;
    color: rgb(250 250 250);
    font-size: 1.55rem;
    font-weight: 600;
    line-height: 1.16;
    letter-spacing: 0;
  }

  .not-found__copy p {
    margin: 0.55rem 0 0;
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.55;
    letter-spacing: 0;
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .escape-link {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border: 1px solid rgb(38 38 38);
    border-radius: 999px;
