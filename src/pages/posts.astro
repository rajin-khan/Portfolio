---
import { getCollection } from "astro:content";
import Layout from "../layouts/main.astro";
import PageHeading from "../components/page-heading.astro";

const POSTS_PER_BATCH = 5;
const allPosts = await getCollection("post");

const sortedPosts = allPosts
  .map((post) => ({
    ...post,
    date: new Date(post.data.date),
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

---

<Layout
  title="Blog"
  description="Essays and practical notes from Rajin Khan about AI, software, design, creative work, and learning in public."
>
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <!-- Animation applied to the heading -->
    <div class="animate-in" style="--animation-delay: 0ms;">
      <PageHeading
        title="Blog Posts"
        description="All the things I love. New Tech, Design, or things I learn as I'm growing my skillset."
      />
    </div>

    <!-- Animation applied to the posts container -->
    <div
      id="posts-container"
      class="z-50 flex flex-col items-stretch w-full gap-5 my-8 animate-in"
      style="--animation-delay: 200ms;"
    >
      {
        sortedPosts.map((post, index) => (
          <article
            class="post-card"
            data-blog-post
            hidden={index >= POSTS_PER_BATCH}
          >
            <a
              href={`/post/${post.slug}`}
              class="relative flex w-full flex-col md:flex-row items-stretch md:justify-between duration-300 ease-out p-7 group h-100 rounded-2xl"
            >
            <span
              class="absolute inset-0 z-20 block w-full h-full duration-300 ease-out bg-transparent border border-transparent border-dashed group-hover:-translate-x-1 group-hover:-translate-y-1 group-hover:border group-hover:border-neutral-300 dark:group-hover:border-neutral-600 group-hover:bg-white dark:group-hover:bg-neutral-950 rounded-2xl"
            ></span>
            <span
              class="absolute inset-0 z-10 block w-full h-full duration-300 ease-out border border-dashed rounded-2xl border-neutral-300 dark:border-neutral-600 group-hover:translate-x-1 group-hover:translate-y-1"
            ></span>

            <div class="relative z-30 duration-300 ease-out group-hover:-translate-x-1 group-hover:-translate-y-1 w-full">
              <div class="flex flex-col md:flex-row items-stretch gap-6 w-full">
                <div class="flex-1">
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {post.data.tags?.map((tag) => (
                      <span class="inline-flex items-center rounded-[0.35rem] border border-white/[0.08] bg-neutral-700/55 px-1.5 py-0.5 text-[0.65rem] font-medium leading-none text-neutral-100/90">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <span class="block w-full px-1 mt-3 mb-1">
                    <span class="flex items-center mb-0 text-base font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
                      {post.data.title}
                      <span class="ml-1 inline-block transition-transform duration-300 translate-x-0 group-hover:translate-x-1">
                        →
                      </span>
                    </span>
                  </span>
                  <span class="text-xs text-neutral-600 dark:text-neutral-400 block truncate overflow-hidden break-words w-full max-w-full">
                    {post.data.description}
                  </span>
                  <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400">
                    Posted on{" "}
                    <time datetime={post.date.toISOString()}>
                      {post.date.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </time>
                  </p>
                </div>
                {post.data.image && (
                  <div class="relative z-30 w-full sm:w-52 h-36 rounded-xl overflow-hidden ml-auto">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                      width="208"
                      height="144"
                    />
                  </div>
                )}
              </div>
            </div>
            </a>
          </article>
        ))
      }
    </div>
    {
      sortedPosts.length > POSTS_PER_BATCH && (
        <div
          id="post-archive-controls"
          class="post-archive-controls flex justify-center mt-8 animate-in"
          style="--animation-delay: 400ms;"
        >
          <button
            id="load-older-posts"
            type="button"
            class="inline-flex items-center justify-center px-4 py-1.5 text-sm font-medium rounded-full border border-neutral-800 dark:border-neutral-200 bg-neutral-800 dark:bg-neutral-200 text-neutral-100 dark:text-neutral-900 transition-[background-color,color,border-color,transform] duration-200 hover:bg-neutral-100 dark:hover:bg-neutral-900 hover:text-neutral-900 dark:hover:text-neutral-100 active:scale-[0.98]"
            aria-controls="posts-container"
            aria-expanded="false"
            data-batch-size={POSTS_PER_BATCH}
          >
            Load older posts
          </button>
          <span id="post-archive-status" class="sr-only" aria-live="polite">
            Showing {POSTS_PER_BATCH} of {sortedPosts.length} posts.
          </span>
        </div>
      )
    }
  </section>
</Layout>

<noscript>
  <style>
    [data-blog-post][hidden] {
      display: block !important;
    }

    .post-archive-controls {
      display: none !important;
    }
  </style>
</noscript>

<script>
  function initializePostArchive() {
    const button = document.getElementById("load-older-posts");
    const postsContainer = document.getElementById("posts-container");
    const controls = document.getElementById("post-archive-controls");
    const status = document.getElementById("post-archive-status");

    if (
      !(button instanceof HTMLButtonElement) ||
      !(postsContainer instanceof HTMLElement) ||
      !(controls instanceof HTMLElement) ||
      button.dataset.bound === "true"
    ) {
      return;
    }

    button.dataset.bound = "true";
    const batchSize = Number(button.dataset.batchSize) || 5;
    const allPosts = Array.from(
      postsContainer.querySelectorAll<HTMLElement>("[data-blog-post]")
    );

    button.addEventListener("click", () => {
      const postsToReveal = allPosts
        .filter((post) => post.hidden)
        .slice(0, batchSize);

      postsToReveal.forEach((post) => {
        post.hidden = false;
        requestAnimationFrame(() => post.classList.add("is-revealed"));
      });

      const remainingCount = allPosts.filter((post) => post.hidden).length;
      const visibleCount = allPosts.length - remainingCount;

      if (status) {
        status.textContent = `Showing ${visibleCount} of ${allPosts.length} posts.`;
      }

      if (remainingCount === 0) {
        button.setAttribute("aria-expanded", "true");
        controls.hidden = true;
      }
    });
  }

  initializePostArchive();
  document.addEventListener("astro:page-load", initializePostArchive);
</script>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .post-card.is-revealed {
      animation: reveal-post 360ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  }

  @keyframes reveal-post {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
