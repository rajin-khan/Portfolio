---
import Layout from "../layouts/main.astro";

const commitPlaceholders = Array.from({ length: 100 });
const eventPlaceholders = Array.from({ length: 30 });
const hourPlaceholders = Array.from({ length: 24 });
const weekdayPlaceholders = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
const languagePlaceholders = Array.from({ length: 6 });
const repositoryPlaceholders = Array.from({ length: 5 });
const commitLogPlaceholders = Array.from({ length: 5 });
---

<Layout
  title="GitHub Activity"
  description="A live public snapshot of Rajin Khan's GitHub repositories, commits, languages, and recent development activity."
  ogImage="/assets/images/rajins-banner-new.png"
  ogImageAlt="Rajin Khan's public GitHub activity"
>
  <div
    class="github-page"
    data-github-dashboard
    data-state="loading"
    aria-busy="true"
  >
    <header class="github-nav">
      <a href="/" class="home-link">
        <svg
          aria-hidden="true"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        <span>Home</span>
      </a>

      <div class="nav-meta">
        <span data-dashboard-updated>Reading the public trail...</span>
        <a
          data-profile-link
          href="https://github.com/rajin-khan"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Rajin Khan on GitHub"
          title="Open GitHub profile"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"
            ></path>
          </svg>
        </a>
      </div>
    </header>

    <div class="dashboard-alert" data-dashboard-error role="alert" hidden>
      <p data-dashboard-error-message>GitHub is being quiet right now.</p>
      <div>
        <button type="button" data-dashboard-retry>Try again</button>
        <a
          data-profile-link
          href="https://github.com/rajin-khan"
          target="_blank"
          rel="noopener noreferrer">Open GitHub</a
        >
      </div>
    </div>

    <aside
      id="commit-day-details"
      class="commit-popover"
      data-commit-popover
      data-open="false"
      role="dialog"
      aria-label="Commit details"
      aria-live="polite"
      hidden
    >
      <div class="commit-popover-meta">
        <time data-commit-popover-date datetime="">A quiet day</time>
        <span data-commit-popover-count>0 commits</span>
      </div>
      <strong data-commit-popover-message>Nothing public landed here</strong>
      <span class="commit-popover-repository" data-commit-popover-repository>
        the square still gets to exist
      </span>
      <a
        data-commit-popover-link
        href="https://github.com/rajin-khan"
        target="_blank"
        rel="noopener noreferrer"
        hidden
      >
        <span>View commit</span>
        <svg
          aria-hidden="true"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </aside>

    <main class="github-main">
      <section class="github-hero" aria-labelledby="github-title">
        <div class="hero-profile">
          <div class="profile-lockup">
            <img
              data-profile-avatar
              src="https://avatars.githubusercontent.com/u/121302497?v=4"
              alt="Rajin Khan's GitHub avatar"
              width="112"
              height="112"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            <div>
              <h1 id="github-title">github</h1>
            </div>
          </div>

          <p class="hero-line">i do like building.</p>

          <div class="profile-details">
            <a
              data-profile-link
              data-profile-handle
              href="https://github.com/rajin-khan"
              target="_blank"
              rel="noopener noreferrer">@rajin-khan</a
            >
            <span data-profile-since>on GitHub since 2022</span>
          </div>

          <div class="hero-count">
            <div class="hero-total-row">
              <strong class="hero-total" data-total-commits>----</strong>
              <span class="hero-plus" aria-hidden="true">+</span>
            </div>
            <p class="hero-total-label">public commits</p>

            <dl class="hero-facts">
              <div>
                <dt>Repositories</dt>
                <dd data-public-repos>--</dd>
              </div>
              <div>
                <dt>Stars earned</dt>
                <dd data-total-stars>--</dd>
              </div>
              <div>
                <dt>Forks</dt>
                <dd data-total-forks>--</dd>
              </div>
              <div>
                <dt>Followers</dt>
                <dd data-followers>--</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="hero-activity">
          <header class="section-heading commit-field-heading">
            <div>
              <h2 id="commit-field-title">The latest hundred.</h2>
              <p class="section-aside">one square, one day</p>
            </div>
            <span data-commit-sample>Reading the last 100 days...</span>
          </header>

          <div class="commit-field-layout">
            <figure class="commit-field-figure">
              <figcaption>
                <span>oldest day</span>
                <span data-commit-range>fetching the range</span>
                <span>newest day</span>
              </figcaption>
              <div
                class="commit-grid"
                data-commit-grid
                role="group"
                aria-label="Public commits across the last 100 days"
                aria-busy="true"
              >
                {
                  commitPlaceholders.map(() => (
                    <span class="commit-pixel commit-pixel--skeleton" aria-hidden="true"></span>
                  ))
                }
              </div>
            </figure>

            <article class="head-commit" aria-label="Most recent public commit">
              <span class="head-octocat" aria-hidden="true">
                <img
                  src="/assets/images/github/octocat-loading.gif"
                  alt=""
                  width="384"
                  height="384"
                  loading="eager"
                  decoding="async"
                />
              </span>
              <p class="head-label">HEAD</p>
              <a
                class="head-sha"
                data-head-link
                href="https://github.com/rajin-khan"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span aria-hidden="true">+</span>
                <code data-head-sha>-------</code>
              </a>
              <h3 data-head-message>Reading the newest commit...</h3>
              <div class="head-meta">
                <a
                  data-head-repository
                  href="https://github.com/rajin-khan"
                  target="_blank"
                  rel="noopener noreferrer">Public repository</a
                >
                <time data-head-date datetime="">just now</time>
              </div>
              <p class="head-aside">currently at the top of the pile</p>
            </article>
          </div>
        </div>
      </section>

      <section class="data-section public-month-section" aria-labelledby="public-month-title">
        <div class="section-inner">
          <header class="section-heading">
            <div>
              <h2 id="public-month-title">Last month I...</h2>
              <p class="section-aside month-note" data-month-note>
                reading the month (-- commits)
              </p>
            </div>
            <span>the last 30 days</span>
          </header>

          <figure class="event-figure">
            <div
              class="event-chart"
              data-event-chart
              role="group"
              aria-label="Public GitHub commits over the last 30 days"
              aria-busy="true"
            >
              {
                eventPlaceholders.map((_, index) => (
                  <span class="event-column" aria-hidden="true">
                    <span
                      class="event-bar-track"
                      style={`--event-height: ${20 + ((index * 17) % 72)}%`}
                    >
                      <span
                        class="event-bar event-bar--skeleton"
                      ></span>
                      <span class="event-count">--</span>
                    </span>
                    <span class="event-date"></span>
                  </span>
                ))
              }
            </div>
          </figure>

          <dl class="event-facts">
            <div>
              <dt>Commits</dt>
              <dd data-month-commits>--</dd>
            </div>
            <div>
              <dt>Active days</dt>
              <dd data-month-active-days>--</dd>
            </div>
            <div>
              <dt>Busiest day</dt>
              <dd data-month-busiest>--</dd>
            </div>
            <div>
              <dt>Repositories</dt>
              <dd data-month-repositories>--</dd>
            </div>
          </dl>
        </div>
      </section>

      <section class="data-section analysis-section" aria-label="GitHub activity analysis">
        <div class="section-inner analysis-grid">
          <article class="rhythm-panel">
            <header class="analysis-heading">
              <h2>Commit rhythm</h2>
              <p class="section-aside" data-rhythm-note>finding the pattern</p>
            </header>

            <figure class="hour-figure">
              <figcaption>
                <span>Hour of day / latest 100</span>
                <span class="rhythm-readout" data-rhythm-readout>
                  tap a bar, it has opinions
                </span>
              </figcaption>
              <div
                class="hour-chart"
                data-hour-chart
                role="group"
                aria-label="Recent commits grouped by hour of day"
                aria-busy="true"
              >
                {
                  hourPlaceholders.map((_, index) => (
                    <span class="hour-column" aria-hidden="true">
                      <span
                        class="hour-bar hour-bar--skeleton"
                        style={`--hour-height: ${18 + ((index * 23) % 76)}%`}
                      ></span>
                      <span class="hour-label">{index % 6 === 0 ? String(index).padStart(2, "0") : ""}</span>
                    </span>
                  ))
                }
              </div>
            </figure>

            <div
              class="weekday-chart"
              data-weekday-chart
              role="group"
              aria-label="Recent commits grouped by weekday"
              aria-busy="true"
            >
              {
                weekdayPlaceholders.map((day, index) => (
                  <span class="weekday-row" aria-hidden="true">
                    <span class="weekday-name">{day}</span>
                    <span class="weekday-track">
                      <span
                        class="weekday-bar weekday-bar--skeleton"
                        style={`--weekday-width: ${34 + index * 8}%`}
                      ></span>
                    </span>
                    <span class="weekday-value">--</span>
                  </span>
                ))
              }
            </div>
          </article>

          <article class="language-panel">
            <header class="analysis-heading">
              <h2>What it's made of</h2>
              <p class="section-aside" data-language-note>counting languages</p>
            </header>
            <p class="analysis-caption">Primary language across owned, active repositories.</p>
            <ol class="language-list" data-language-list aria-busy="true">
              {
                languagePlaceholders.map((_, index) => (
                  <li class="language-row language-row--skeleton" aria-hidden="true">
                    <span class="language-rank">{String(index + 1).padStart(2, "0")}</span>
                    <span class="language-content">
                      <span class="language-heading">
                        <span class="language-name">Reading...</span>
                        <span class="language-count">-- repos</span>
                      </span>
                      <span class="language-track">
                        <span
                          class="language-bar"
                          style={`--language-width: ${96 - index * 11}%`}
                        ></span>
                      </span>
                    </span>
                  </li>
                ))
              }
            </ol>
          </article>
        </div>
      </section>

      <section class="data-section code-index-section" aria-label="Repositories and recent commits">
        <div class="section-inner code-index-grid">
          <article class="repositories-panel" aria-labelledby="repositories-title">
            <header class="section-heading">
              <div>
                <h2 id="repositories-title">Worth opening</h2>
                <p>Public repositories, ordered by the attention they found.</p>
              </div>
              <a
                href="https://github.com/rajin-khan?tab=repositories"
                target="_blank"
                rel="noopener noreferrer"
              >All repositories</a>
            </header>

            <ol class="repository-list" data-repository-list aria-busy="true">
              {
                repositoryPlaceholders.map((_, index) => (
                  <li class="repository-item repository-item--skeleton" aria-hidden="true">
                    <span class="repository-link">
                      <span class="repository-rank">{String(index + 1).padStart(2, "0")}</span>
                      <span class="repository-copy">
                        <strong class="repository-name">Reading repository...</strong>
                        <span class="repository-description">Waiting for GitHub metadata.</span>
                      </span>
                      <span class="repository-facts">-- language / -- stars</span>
                      <span class="repository-arrow" aria-hidden="true">↗</span>
                    </span>
                  </li>
                ))
              }
            </ol>
          </article>

          <article class="commit-log-panel" aria-labelledby="commit-log-title">
            <header class="section-heading">
              <div>
                <h2 id="commit-log-title">Recent commits</h2>
                <p>The messages say more than the graph does.</p>
              </div>
              <span data-commit-log-count>Reading the log...</span>
            </header>

            <ol class="commit-log" data-commit-list aria-busy="true">
              {
                commitLogPlaceholders.map(() => (
                  <li class="commit-log-item commit-log-item--skeleton" aria-hidden="true">
                    <span class="commit-log-link">
                      <code class="commit-log-sha">-------</code>
                      <span class="commit-log-copy">
                        <strong class="commit-log-message">Reading commit message...</strong>
                        <span class="commit-log-repository">repository</span>
                      </span>
                      <time class="commit-log-date">--</time>
                      <span class="commit-log-arrow" aria-hidden="true">↗</span>
                    </span>
                  </li>
                ))
              }
            </ol>
          </article>
        </div>
      </section>

      <p class="dashboard-api-note" data-api-note hidden></p>
    </main>
  </div>

  <script src="../assets/js/github-dashboard.js"></script>
</Layout>

<style is:global>
  @font-face {
    font-family: "La Belle Aurore";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/assets/fonts/la-belle-aurore-latin.woff2") format("woff2");
  }

  header#header,
  body > div.relative.w-full.h-20[aria-hidden="true"],
  .square-lines {
    display: none !important;
  }

  body {
    overflow-x: hidden;
    background: #080808 !important;
  }

  body > footer {
    margin-top: 0 !important;
  }

  #main-content {
    outline: none;
  }

  .github-page {
    --ink: #080808;
    --ink-raised: #0d0d0d;
    --paper: #f1f1ee;
    --muted: #9a9a96;
    --faint: #666662;
    --line: rgba(255, 255, 255, 0.14);
    --line-strong: rgba(255, 255, 255, 0.28);
    --activity-0: #161b22;
    --activity-1: #0e4429;
    --activity-2: #006d32;
    --activity-3: #26a641;
    --activity-4: #39d353;
    min-height: 100svh;
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
    color: var(--paper);
    background-color: var(--ink);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 88px 88px;
    font-family: "Satoshi", ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
  }

  .github-page *,
  .github-page *::before,
  .github-page *::after {
    box-sizing: border-box;
  }

  .github-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    min-height: 72px;
    width: 100%;
    padding: 0 36px;
    border-bottom: 1px solid var(--line);
    background: rgba(8, 8, 8, 0.92);
    backdrop-filter: blur(16px);
  }

  .home-link,
  .nav-meta,
  .nav-meta a,
  .profile-details,
  .head-meta,
  .section-heading,
  .repository-facts {
    display: flex;
    align-items: center;
  }

  .home-link,
  .nav-meta a,
  .profile-details a,
  .head-commit a,
  .section-heading a,
  .repository-link,
  .commit-log-link,
  .dashboard-alert a {
    color: inherit;
    text-decoration: none;
  }

  .home-link {
    justify-self: start;
    gap: 9px;
    color: #b8b8b4;
    font-size: 0.78rem;
    font-weight: 600;
    transition: color 180ms ease;
  }

  .home-link svg {
    transition: transform 180ms ease;
  }

  .home-link:hover {
    color: var(--paper);
  }

  .home-link:hover svg {
    transform: translateX(-3px);
  }

  .nav-meta {
    justify-self: end;
    gap: 14px;
    color: var(--faint);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .nav-meta a {
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 1px solid var(--line);
    border-radius: 50%;
    color: #bcbcb8;
    transition:
      color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .nav-meta a:hover {
    border-color: var(--line-strong);
    color: var(--paper);
    transform: rotate(-5deg);
  }

  .nav-meta svg {
    width: 15px;
    height: 15px;
  }

  .dashboard-alert {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    width: min(1180px, calc(100% - 48px));
    margin: 22px auto 0;
    padding: 14px 16px;
    border: 1px dashed var(--line-strong);
    border-radius: 8px;
    background: #101010;
    color: #cfcfcb;
    font-size: 0.78rem;
  }

  .dashboard-alert[hidden] {
    display: none;
  }

  .dashboard-alert p {
    margin: 0;
  }

  .dashboard-alert div {
    display: flex;
    gap: 8px;
  }

  .dashboard-alert button,
  .dashboard-alert a {
    padding: 7px 11px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: #171717;
    color: var(--paper);
    font: inherit;
    cursor: pointer;
  }

  .github-main {
    position: relative;
    z-index: 1;
  }

  .github-hero,
  .section-inner {
    width: min(1180px, calc(100% - 72px));
    margin: 0 auto;
  }

  .github-hero {
    display: grid;
    grid-template-columns: minmax(290px, 0.72fr) minmax(0, 1.48fr);
    align-items: stretch;
    gap: 68px;
    min-height: calc(100svh - 72px);
    padding: 58px 0 70px;
  }

  .hero-profile {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
    padding-right: 54px;
    border-right: 1px solid var(--line);
  }

  .profile-lockup {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .profile-lockup img {
    width: 88px;
    height: 88px;
    border: 1px dashed #5f5f5c;
    border-radius: 50%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.03);
  }

  .profile-lockup h1 {
    margin: 0;
    color: var(--paper);
    font-size: 4.45rem;
    font-weight: 800;
    line-height: 0.82;
    letter-spacing: 0;
  }

  .hero-line {
    max-width: 18ch;
    margin: 31px 0 0;
    color: #deded9;
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.15;
    transform: rotate(-1deg);
  }

  .section-aside,
  .head-aside {
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-weight: 400;
    letter-spacing: 0;
  }

  .profile-details {
    flex-wrap: wrap;
    gap: 8px 0;
    margin-top: 27px;
    color: var(--faint);
    font-size: 0.72rem;
    font-weight: 600;
  }

  .profile-details > * {
    display: inline-flex;
    align-items: center;
  }

  .profile-details > *:not(:last-child)::after {
    width: 3px;
    height: 3px;
    margin: 0 10px;
    border-radius: 50%;
    background: #555552;
    content: "";
  }

  .profile-details a {
    color: #c8c8c4;
  }

  .profile-details a:hover {
    color: var(--paper);
  }

  .hero-count {
    position: relative;
    min-width: 0;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  .hero-total-row {
    display: flex;
    align-items: flex-end;
    gap: 9px;
  }

  .hero-plus {
    color: #555552;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 0.82;
    padding-bottom: 7px;
    pointer-events: none;
  }

  .hero-total {
    display: block;
    color: var(--paper);
    font-size: 4.6rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 0.9;
    letter-spacing: 0;
  }

  .hero-total-label {
    margin: 15px 0 0;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .hero-facts,
  .event-facts {
    display: grid;
    margin: 0;
  }

  .hero-facts {
    grid-template-columns: repeat(2, 1fr);
    column-gap: 24px;
    max-width: 390px;
    margin-top: 30px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .hero-facts div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 14px;
    min-width: 0;
    padding: 10px 0;
  }

  .hero-facts div + div {
    border-left: 0;
