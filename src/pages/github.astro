  }

  .event-count {
    position: absolute;
    bottom: calc(var(--event-height) + 7px);
    left: 50%;
    z-index: 4;
    display: block;
    width: max-content;
    padding: 5px 8px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: #171717;
    color: #f1f1ee;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
