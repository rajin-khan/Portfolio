    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .commit-popover {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 60;
    display: grid;
    gap: 10px;
    width: min(330px, calc(100vw - 32px));
    padding: 16px;
    border: 1px solid rgba(255, 255, 255, 0.24);
