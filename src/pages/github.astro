  .commit-popover[hidden] {
    display: none;
  }

  .commit-popover[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .commit-popover-meta {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: #909690;
    font-size: 0.6rem;
    font-weight: 650;
    font-variant-numeric: tabular-nums;
    text-transform: uppercase;
  }

  .commit-popover > strong {
    color: #f0f0ec;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.8rem;
    font-weight: 550;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .commit-popover-repository {
    color: #929a94;
    font-size: 0.66rem;
    font-weight: 600;
  }

  .commit-popover > a {
    display: inline-flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    width: 100%;
    margin-top: 3px;
    padding: 9px 11px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    background: #171717;
    color: #e8eae6;
    font-size: 0.66rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .commit-popover > a[hidden] {
    display: none;
  }

  .commit-popover > a:hover {
    border-color: rgba(255, 255, 255, 0.34);
    background: #1b1b1b;
  }

  .commit-pixel--level-0 {
