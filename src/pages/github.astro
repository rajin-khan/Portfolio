    transform: translate(0, 0);
  }

  .event-column:last-child .event-count {
    right: 0;
    left: auto;
    transform: translate(0, 4px);
  }

  .event-column:last-child:hover .event-count,
  .event-column:last-child:focus-visible .event-count,
  .event-column:last-child[aria-pressed="true"] .event-count {
