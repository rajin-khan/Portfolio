---
import experiences from "../collections/experiences.json";
import AboutExperience from "../components/about-experience.astro";
import Layout from "../layouts/main.astro";

type TimelineExperience = (typeof experiences)[number] & {
	kind: "work" | "education";
};

const timelineExperiences = experiences as TimelineExperience[];
const pageDescription =
	"Meet Rajin Khan, an AI engineer, developer, and Computer Science student in Dhaka working across generative AI, computer vision, and thoughtful digital products.";
const profileSchema = {
	"@context": "https://schema.org",
	"@type": "ProfilePage",
	"@id": "https://rajinkhan.com/about/#profile",
	url: "https://rajinkhan.com/about/",
	name: "About Rajin Khan",
	description: pageDescription,
	mainEntity: {
		"@type": "Person",
		"@id": "https://rajinkhan.com/#person",
		name: "Rajin Khan",
		alternateName: "Adib Ar Rahman Khan",
		jobTitle: "AI Engineer",
		image: "https://rajinkhan.com/assets/images/rajin-darkbg-tiny.png",
		url: "https://rajinkhan.com/",
		sameAs: [
			"https://github.com/rajin-khan",
			"https://www.linkedin.com/in/rajin-khan/",
			"https://www.instagram.com/raaajiin/",
		],
	},
};
---

<Layout
  title="About"
  description={pageDescription}
  ogImage="/assets/images/rajin-darkbg-tiny.png"
  ogImageAlt="Portrait of Rajin Khan"
  structuredData={profileSchema}
>
  <section class="about-page" aria-labelledby="about-title">
    <div class="about-shell">
      <header class="about-heading">
        <div class="about-title-block">
          <h1 id="about-title">A little about me</h1>
          <p class="about-handwritten">still figuring it out. still making things.</p>
        </div>
      </header>

      <div class="about-profile">
        <div class="portrait-stage">
          <button
            type="button"
            class="portrait-stack"
            data-portrait-stack
            data-swapped="false"
            aria-label="Swap Rajin's portrait"
            aria-pressed="false"
          >
            <span class="polaroid-card polaroid-back" data-portrait-card="back">
              <span class="photo-window">
                <img
                  src="/assets/images/rajin-smiling-yet-again.jpg"
                  alt="Rajin Khan smiling in a black hoodie"
                  width="1242"
                  height="1242"
                  loading="eager"
                  decoding="async"
                />
              </span>
              <span class="portrait-signature portrait-signature-back" aria-hidden="true">
                <span>also him.</span>
                <svg viewBox="0 0 150 18" role="presentation">
                  <path pathLength="1" d="M4 11.5C34 7.2 75 5.4 146 8.5" />
                </svg>
              </span>
            </span>

            <span class="polaroid-card polaroid-front" data-portrait-card="front">
              <span class="photo-window">
                <img
                  src="/assets/images/rajin-just-smiling.jpg"
                  alt="Rajin Khan smiling at a restaurant"
                  width="1242"
                  height="1242"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </span>
              <span class="portrait-signature portrait-signature-front" aria-hidden="true">
                <span>Rajin</span>
                <svg viewBox="0 0 150 18" role="presentation">
                  <path pathLength="1" d="M34 11.5C57 7.2 88 5.6 133 8.5" />
                </svg>
              </span>
            </span>
          </button>
          <span class="sr-only" aria-live="polite" data-portrait-status></span>
        </div>

        <article class="about-copy">
          <p class="about-role">AI engineer &middot; developer &middot; designer</p>
          <h2>Rajin Khan</h2>
          <div class="about-body">
            <p>
              Hey, I'm Rajin, a Computer Science student in Dhaka. I work across
              generative AI, computer vision, web development, and design.
            </p>
            <p>
              I like making machines think, then obsessing over how the result looks and
              feels. Useful is good. Useful and beautiful is better.
            </p>
            <p class="formal-name">
              My formal name is Adib Ar Rahman Khan. If that shows up on a resume and
              briefly makes you wonder who you have been reading about, it is still me.
            </p>
          </div>

          <dl class="about-facts">
            <div>
              <dt>based in</dt>
              <dd>Dhaka, Bangladesh</dd>
            </div>
            <div>
              <dt>usually building</dt>
              <dd>AI systems and thoughtful interfaces</dd>
            </div>
          </dl>
        </article>
      </div>
    </div>
  </section>

  <section class="about-experience-section" aria-labelledby="experience-title">
    <div class="about-lower-shell">
      <header class="experience-heading">
        <div>
          <h2 id="experience-title">Education &amp; experience</h2>
          <p>the route here wasn't exactly straight.</p>
        </div>
        <span class="experience-range">2006 <span aria-hidden="true">&rarr;</span> now</span>
      </header>

      <div class="timeline-axis-labels" aria-hidden="true">
        <span>Experience</span>
        <i></i>
        <span>Education</span>
      </div>

      <div class="experience-list">
        {
          timelineExperiences.map((experience) => (
            <AboutExperience
              dates={experience.dates}
              role={experience.role}
              company={experience.company}
              description={experience.description}
              logo={experience.logo}
              kind={experience.kind}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="about-contact" aria-labelledby="contact-title">
    <div class="about-contact-shell">
      <div class="contact-copy">
        <p class="contact-note">okay, so...</p>
        <h2 id="contact-title">Down to connect?</h2>
        <p class="contact-message">
          Want to reach out? I'm almost always on Instagram.
          Recruiters can email me and I'll get back to you STAT.
        </p>
      </div>

      <div class="contact-actions">
        <a
          class="contact-action contact-action-primary"
          href="https://www.instagram.com/raaajiin/"
          target="_blank"
          rel="me noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4.1"></circle>
            <circle class="contact-icon-dot" cx="17.4" cy="6.7" r="1"></circle>
          </svg>
          <span>Instagram</span>
        </a>
        <a
          class="contact-action"
          href="mailto:rajin.khan2001@gmail.com?subject=Let's%20Connect&body=Hi%20Rajin,"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3.5 6.5h17v11h-17z"></path>
            <path d="m4 7 8 6 8-6"></path>
          </svg>
          <span>Email me</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-page {
    --about-paper: #f2f2ef;
    --about-muted: #aaa9a5;
    --about-faint: #777773;
    --about-line: rgba(255, 255, 255, 0.12);
    position: relative;
    z-index: 20;
    padding: 40px 28px 0;
    color: var(--about-paper);
  }

  .about-shell {
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .about-heading {
    padding: 28px 0 62px;
    text-align: center;
    opacity: 0;
    animation: about-enter 650ms cubic-bezier(0.16, 1, 0.3, 1) 80ms forwards;
  }

  .about-role,
  .about-facts dt {
    margin: 0;
    color: var(--about-faint);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .about-title-block h1 {
    margin: 0;
    color: var(--about-paper);
    font-size: 3.75rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
    text-wrap: balance;
  }

  .about-handwritten {
    margin: 18px 0 0;
    color: #fff;
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.45;
    transform: rotate(-1deg);
    transform-origin: center;
  }

  .about-profile {
    display: grid;
    grid-template-columns: minmax(340px, 0.84fr) minmax(0, 1.16fr);
    gap: 96px;
    align-items: center;
    padding: 18px 0 52px;
    opacity: 0;
    animation: about-enter 720ms cubic-bezier(0.16, 1, 0.3, 1) 180ms forwards;
  }

  .portrait-stage {
    display: flex;
    min-width: 0;
    min-height: 470px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
  }

  .portrait-stack {
    position: relative;
    display: block;
    width: min(300px, calc(100vw - 104px));
    aspect-ratio: 0.84;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    isolation: isolate;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .polaroid-card {
    position: absolute;
    inset: 0;
    display: block;
    padding: 15px 15px 56px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 3px;
    background: #090909;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.34);
    transform-origin: center;
    pointer-events: none;
    will-change: transform;
  }

  .polaroid-front {
    z-index: 2;
    transform: rotate(-5deg);
  }

  .polaroid-back {
    z-index: 1;
    transform: rotate(5deg);
  }

  .photo-window {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #141414;
  }

  .photo-window::after {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    content: "";
    pointer-events: none;
  }

  .photo-window img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .polaroid-front .photo-window img {
    object-position: center 42%;
  }

  .polaroid-back .photo-window img {
    object-position: center 38%;
  }

  .portrait-signature {
    position: absolute;
    right: 20px;
    bottom: 25px;
    display: block;
    width: 142px;
    color: #fff;
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
    text-align: center;
    transform: rotate(-4deg);
    transform-origin: center;
  }

  .portrait-signature > span {
    display: block;
  }

  .portrait-signature-front > span {
    margin: -0.18em -0.2em -0.3em;
    padding: 0.18em 0.2em 0.3em;
    -webkit-mask-image: linear-gradient(90deg, #000 0 50%, transparent 50% 100%);
    mask-image: linear-gradient(90deg, #000 0 50%, transparent 50% 100%);
    -webkit-mask-position: 100% 0;
    mask-position: 100% 0;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 200% 100%;
    mask-size: 200% 100%;
    animation: signature-paint var(--signature-name-duration) linear var(--signature-start)
      forwards;
    will-change: mask-position;
  }

  .portrait-signature-front {
    --signature-start: 650ms;
    --signature-name-duration: 1020ms;
    --signature-line-duration: 140ms;
    right: 7px;
    bottom: 26px;
    font-size: 1.82rem;
  }

  .portrait-signature-back {
    width: 118px;
    font-size: 1.45rem;
    transform: rotate(3deg);
  }

  .portrait-signature-back svg {
    display: none;
  }

  .portrait-signature svg {
    position: absolute;
    right: 0;
    bottom: -9px;
    width: 100%;
    overflow: visible;
  }

  .portrait-signature path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 0;
  }

  .portrait-signature-front path {
    stroke-linecap: butt;
    stroke-dasharray: 1 1;
    stroke-dashoffset: 1;
    opacity: 0;
    animation: signature-draw var(--signature-line-duration) cubic-bezier(0.16, 1, 0.3, 1)
      calc(var(--signature-start) + var(--signature-name-duration)) forwards;
  }

  .portrait-signature-front svg {
    right: 2%;
    width: 78%;
  }

  .portrait-stack:focus-visible {
    outline: none;
  }

  .portrait-stack[data-swapped="true"]:focus-visible .polaroid-back,
  .portrait-stack:not([data-swapped="true"]):focus-visible .polaroid-front {
    box-shadow:
      0 0 0 2px #d4d4d4,
      0 28px 70px rgba(0, 0, 0, 0.34);
  }

  .about-copy {
    min-width: 0;
    max-width: 620px;
  }

  .about-role {
    color: #8c8c88;
  }

  .about-copy h2 {
    margin: 13px 0 0;
    color: var(--about-paper);
    font-size: 2.65rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.05;
  }

  .about-body {
    display: grid;
    gap: 18px;
    margin-top: 30px;
  }

  .about-body p {
    max-width: 58ch;
    margin: 0;
    color: #b6b6b2;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.72;
    text-wrap: pretty;
  }

  .about-body .formal-name {
    color: #858581;
    font-size: 0.9rem;
  }

  .about-facts {
    display: grid;
    grid-template-columns: minmax(120px, 0.7fr) minmax(0, 1.3fr);
    gap: 28px;
    margin: 38px 0 0;
    padding-top: 24px;
    border-top: 1px solid var(--about-line);
  }

  .about-facts div {
    min-width: 0;
  }

  .about-facts dd {
    margin: 7px 0 0;
    color: #d2d2cf;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.45;
    text-wrap: pretty;
  }

  .about-experience-section {
    position: relative;
    z-index: 20;
    padding: 52px 28px 72px;
    color: #ededeb;
  }

  .about-lower-shell {
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .experience-heading {
    display: flex;
    align-items: center;
    flex-direction: column;
    padding: 10px 0 34px;
    text-align: center;
  }

  .experience-heading h2 {
    margin: 0;
    color: #ededeb;
    font-size: 2.45rem;
    font-weight: 700;
    line-height: 1.05;
    text-wrap: balance;
  }

  .experience-heading p {
    margin: 12px 0 0;
    color: #fff;
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 1.04rem;
    font-weight: 400;
    line-height: 1.35;
    transform: rotate(-1deg);
    transform-origin: center;
  }

  .experience-range {
    margin-top: 18px;
    color: #777773;
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    font-weight: 650;
    line-height: 1;
    white-space: nowrap;
  }

  .experience-range span {
    display: inline-block;
    margin: 0 8px;
    color: #aaa9a5;
  }

  .timeline-axis-labels {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 94px 1px 94px minmax(0, 1fr);
    align-items: center;
    margin: 8px 0 28px;
  }

  .timeline-axis-labels span {
    color: #858581;
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .timeline-axis-labels span:first-child {
    grid-column: 1 / 3;
    justify-self: end;
    margin-right: 18px;
  }

  .timeline-axis-labels span:last-child {
    grid-column: 4 / 6;
    justify-self: start;
    margin-left: 18px;
  }

  .timeline-axis-labels i {
    grid-column: 3;
    width: 7px;
    height: 7px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 50%;
    background: #090909;
    box-shadow: 0 0 0 6px #090909;
    transform: translateX(-3px);
  }

  .experience-list {
    position: relative;
    width: 100%;
    margin: 0;
  }

  .experience-list::before {
    position: absolute;
    z-index: 0;
    top: 26px;
    bottom: 26px;
    left: 50%;
    width: 1px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.08),
      rgba(255, 255, 255, 0.24) 8%,
      rgba(255, 255, 255, 0.15) 92%,
      rgba(255, 255, 255, 0.06)
    );
    content: "";
    transform: translateX(-0.5px);
  }

  .about-contact {
    position: relative;
    z-index: 20;
    padding: 0 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.11);
    border-bottom: 1px solid rgba(255, 255, 255, 0.11);
    background: rgba(255, 255, 255, 0.018);
  }

  .about-contact-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 72px;
    align-items: center;
    width: min(100%, 1120px);
    margin: 0 auto;
    padding: 62px 0 66px;
  }

  .contact-copy {
    min-width: 0;
  }

  .contact-note {
    margin: 0 0 10px 8px;
    color: #fff;
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.35;
    transform: rotate(-1deg);
    transform-origin: left center;
  }

  .contact-copy h2 {
    margin: 0;
    color: #ededeb;
    font-size: 2.55rem;
    font-weight: 700;
    line-height: 1.05;
    text-wrap: balance;
  }

  .contact-message {
    max-width: 57ch;
    margin: 18px 0 0;
    color: #a5a5a1;
    font-size: 0.94rem;
    font-weight: 550;
    line-height: 1.7;
    text-wrap: pretty;
  }

  .contact-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-self: end;
  }

  .contact-action {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 0 17px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    color: #d2d2cf;
    background: rgba(255, 255, 255, 0.025);
    font-size: 0.79rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-action svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  .contact-action .contact-icon-dot {
    fill: currentColor;
    stroke: none;
  }

  .contact-action-primary {
    border-color: #ededeb;
    color: #111;
    background: #ededeb;
  }

  .contact-action:hover {
    border-color: rgba(255, 255, 255, 0.34);
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    transform: translate3d(0, -2px, 0);
  }

  .contact-action-primary:hover {
    border-color: #fff;
    color: #090909;
    background: #fff;
  }

  .contact-action:active {
    transform: translate3d(0, 0, 0) scale(0.98);
  }

  .contact-action:focus-visible {
    outline: 2px solid #ededeb;
    outline-offset: 3px;
  }

  :global(footer) {
    margin-top: 0 !important;
  }

  @keyframes about-enter {
    from {
      opacity: 0;
      transform: translate3d(0, 16px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes signature-paint {
    to {
      -webkit-mask-position: 0 0;
      mask-position: 0 0;
    }
  }

  @keyframes signature-draw {
    0% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
    2% {
      opacity: 1;
      stroke-dashoffset: 0.98;
    }
    to {
      opacity: 1;
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 980px) {
    .about-title-block h1 {
      font-size: 3.35rem;
    }

    .about-profile {
      grid-template-columns: minmax(300px, 0.78fr) minmax(0, 1.22fr);
      gap: 58px;
    }

    .portrait-stage {
      min-height: 430px;
    }

    .portrait-stack {
      width: min(272px, calc(100vw - 104px));
    }
  }

  @media (min-width: 761px) and (max-width: 1100px) {
    .about-page,
    .about-experience-section,
    .about-contact {
      padding-right: clamp(40px, 5vw, 52px);
      padding-left: clamp(40px, 5vw, 52px);
    }

    .about-contact-shell {
      gap: 40px;
    }
  }

  @media (max-width: 720px) {
    .timeline-axis-labels {
      display: none;
    }

    .experience-list::before {
      top: 23px;
      bottom: 23px;
      left: 23px;
      transform: none;
    }
  }

  @media (max-width: 760px) {
    .about-page {
      padding: 24px 20px 0;
    }

    .about-heading {
      padding: 24px 0 44px;
    }

    .about-title-block h1 {
      font-size: 2.8rem;
      line-height: 1.04;
    }

    .about-handwritten {
      margin-top: 14px;
      font-size: 1.02rem;
    }

    .about-profile {
      grid-template-columns: 1fr;
      gap: 42px;
      padding: 0 0 40px;
    }

    .portrait-stage {
      min-height: 0;
      padding: 28px 0 0;
    }

    .portrait-stack {
      width: min(276px, calc(100vw - 88px));
    }

    .about-copy {
      max-width: none;
    }

    .about-copy h2 {
      font-size: 2.2rem;
    }

    .about-body {
      margin-top: 24px;
    }

    .about-experience-section {
      padding: 44px 20px 52px;
    }

    .experience-heading {
      padding: 6px 0 28px;
    }

    .experience-heading h2 {
      font-size: 2.1rem;
    }

    .experience-heading p {
      margin-top: 10px;
      font-size: 0.98rem;
    }

    .about-contact {
      padding: 0 20px;
    }

    .about-contact-shell {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 48px 0 52px;
    }

    .contact-copy h2 {
      font-size: 2.2rem;
    }

    .contact-message {
      margin-top: 15px;
    }

    .contact-note {
      margin-left: 7px;
    }

    .contact-actions {
      justify-self: start;
    }
  }

  @media (max-width: 440px) {
    .about-page {
      padding-right: 16px;
      padding-left: 16px;
    }

    .about-experience-section,
    .about-contact {
      padding-right: 16px;
      padding-left: 16px;
    }

    .portrait-stack {
      width: min(250px, calc(100vw - 76px));
    }

    .polaroid-card {
      padding: 12px 12px 48px;
    }

    .portrait-signature {
      right: 15px;
      bottom: 19px;
      width: 124px;
      font-size: 1.75rem;
    }

    .portrait-signature-back {
      width: 104px;
      font-size: 1.22rem;
    }

    .portrait-signature-front {
      bottom: 22px;
      font-size: 1.6rem;
    }

    .about-facts {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .experience-heading {
      align-items: center;
    }

    .experience-heading h2 {
      font-size: 1.9rem;
    }

    .experience-range {
      margin-top: 15px;
    }

    .contact-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .contact-action {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-heading,
    .about-profile {
      opacity: 1;
      animation: none;
    }

    .portrait-signature-front > span {
      -webkit-mask-position: 0 0;
      mask-position: 0 0;
      animation: none;
    }

    .portrait-signature path {
      opacity: 1;
      stroke-dashoffset: 0;
      animation: none;
    }

    .polaroid-card {
      will-change: auto;
    }

    .contact-action {
      transition: none;
    }
  }
</style>

<script>
  function setupPortraitStack() {
    const stacks = document.querySelectorAll<HTMLElement>("[data-portrait-stack]");

    stacks.forEach((stack) => {
      if (stack.dataset.initialized === "true") return;
      stack.dataset.initialized = "true";

      const front = stack.querySelector<HTMLElement>('[data-portrait-card="front"]');
      const back = stack.querySelector<HTMLElement>('[data-portrait-card="back"]');
      const status = stack.parentElement?.querySelector<HTMLElement>("[data-portrait-status]");
      if (!front || !back) return;

      const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)");
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      let swapped = false;
      let requestedState = false;
      let isAnimating = false;

      const frontRest = "translate3d(0, 0, 0) rotate(-5deg) scale(1)";
      const backRest = "translate3d(0, 0, 0) rotate(5deg) scale(1)";

      const updateState = (nextState: boolean) => {
        swapped = nextState;
        stack.dataset.swapped = String(nextState);
        stack.setAttribute("aria-pressed", String(nextState));
        if (status) status.textContent = nextState ? "Second portrait shown" : "First portrait shown";
      };

      const runSwap = async (showBack: boolean) => {
        const outgoing = showBack ? front : back;
        const incoming = showBack ? back : front;
        const restingTransform = showBack ? frontRest : backRest;
        const liftedTransform = showBack
          ? "translate3d(76px, -52px, 0) rotate(-8deg) scale(1.035)"
          : "translate3d(-76px, -52px, 0) rotate(8deg) scale(1.035)";

        if (reducedMotion.matches) {
          outgoing.style.zIndex = "1";
          incoming.style.zIndex = "2";
          updateState(showBack);
          return;
        }

        const lift = outgoing.animate(
          [
            { transform: restingTransform },
            { transform: liftedTransform },
          ],
          {
            duration: 170,
            easing: "cubic-bezier(0.55, 0, 1, 0.45)",
            fill: "forwards",
          },
        );
        await lift.finished.catch(() => undefined);

        outgoing.style.zIndex = "1";
        incoming.style.zIndex = "2";
        updateState(showBack);

        const settle = outgoing.animate(
          [
            { transform: liftedTransform },
            { transform: restingTransform },
          ],
          {
            duration: 520,
            easing: "cubic-bezier(0.16, 1, 0.3, 1)",
            fill: "none",
          },
        );
        await settle.finished.catch(() => undefined);
        lift.cancel();
      };

      const requestSwap = async (nextState: boolean) => {
        requestedState = nextState;
        if (isAnimating) return;
        isAnimating = true;

        while (swapped !== requestedState) {
          await runSwap(requestedState);
        }

        isAnimating = false;
      };

      stack.addEventListener("mouseenter", () => {
        if (finePointer.matches) void requestSwap(true);
      });
      stack.addEventListener("mouseleave", () => {
        if (finePointer.matches) void requestSwap(false);
      });
      stack.addEventListener("click", (event) => {
        const isPointerClick = event.detail > 0;
        if (isPointerClick && finePointer.matches) return;
        void requestSwap(!requestedState);
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupPortraitStack, { once: true });
  } else {
    setupPortraitStack();
  }
  document.addEventListener("astro:page-load", setupPortraitStack);
</script>
