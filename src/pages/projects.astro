---
import PageHeading from "../components/page-heading.astro";
import Project from "../components/project.astro";
import Layout from "../layouts/main.astro";
import { getProjects } from "../lib/projects";

const projects = await getProjects();
---

<Layout
  title="Projects"
  description="Explore Rajin Khan's work across AI, computer vision, accessibility, full-stack development, creative tools, and experimental software."
>
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <!-- Animation applied to the heading -->
    <div class="animate-in" style="--animation-delay: 0ms;">
      <PageHeading
        title="My Projects"
        description="A selection from some of the projects I've worked on over the years. I love creating digital solutions for all my problems, while working on impactful projects, or random things that pique my interest."
      />
    </div>

    <!-- Animation applied to the entire projects grid -->
    <div
      class="z-50 grid items-stretch w-full grid-cols-1 my-8 gap-7 sm:gap-5 sm:grid-cols-2 animate-in"
      style="--animation-delay: 200ms;"
    >
      {
        projects.map(({ data }) => <Project project={data} />)
      }
    </div>
  </section>
</Layout>
