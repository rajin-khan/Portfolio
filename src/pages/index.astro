---
import Button from "../components/button.astro";
import ChatButton from "../components/chatbutton.astro";
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import Layout from "../layouts/main.astro";
import StatusIndicator from "../components/status-indicator.astro";
import TechStack from "../components/tech-stack.astro";
import LatestCommit from "../components/latest-commit.astro";
import Newsletter from "../components/home/newsletter.astro";
import StickerBoard from "../components/sticker-board.jsx";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://rajinkhan.com/#person",
  name: "Rajin Khan",
  alternateName: "Adib Ar Rahman Khan",
  description:
    "AI engineer, developer, and Computer Science student in Dhaka building thoughtful products across generative AI, computer vision, and the web.",
  url: "https://rajinkhan.com/",
  sameAs: [
    "https://github.com/rajin-khan",
    "https://www.linkedin.com/in/rajin-khan",
    "https://www.instagram.com/raaajiin/",
    "https://www.facebook.com/rajinisdown/",
  ],
  jobTitle: "AI Engineer",
  image: "https://rajinkhan.com/assets/images/rajin-darkbg-tiny.png",
  knowsAbout: [
    "Generative AI",
    "Deep Learning",
    "Machine Learning",
    "Computer Vision",
    "Full-Stack Web Development",
    "UI Design",
  ],
  worksFor: {
    "@type": "Organization",
    name: "Skelementor",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Dhaka",
    addressCountry: "Bangladesh",
  },
  alumniOf: {
    "@type": "School",
    name: "Sunnydale",
  },
  mainEntityOfPage: "https://rajinkhan.com/about/",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://rajinkhan.com/#website",
  name: "Rajin Khan",
  alternateName: ["rajin", "Rajin Khan Portfolio"],
  url: "https://rajinkhan.com/",
  inLanguage: "en",
  publisher: { "@id": "https://rajinkhan.com/#person" },
};

const pageTitle = "Rajin Khan | AI Engineer, Developer & Designer";
const pageDescription =
  "Portfolio and writing by Rajin Khan, an AI engineer and developer in Dhaka building thoughtful products across AI, computer vision, and the web.";
const ogImage = "/assets/images/rajins-banner-new.png";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
  ogImageAlt="Rajin Khan, AI engineer, developer, and designer"
  structuredData={[websiteSchema, personSchema]}
>
  <div
    class="relative z-20 w-full max-w-4xl mx-auto mt-16 px-7 md:mt-24 lg:mt-32 xl:px-0"
  >
    <!-- Animation applied to the entire hero section -->
    <section
      class="flex flex-col-reverse md:flex-row items-center animate-in"
      style="--animation-delay: 0ms;"
    >
      <div class="relative w-full md:w-1/2">
        <h1
          class="mb-5 text-4xl font-bold leading-tight md:text-4xl lg:text-6xl dark:text-white"
        >
          Hey, I'm Rajin.
        </h1>
        <p class="hero-handwritten mb-6 text-[1.375rem] leading-relaxed text-neutral-700 dark:text-neutral-300">
          I make machines think so I don't have to. <br
            class="hidden lg:block"
          />
        </p>
        <h2 class="mb-2 font-semibold text-neutral-800 dark:text-neutral-200">
          Obsessions:
        </h2>
        <ul
          class="py-2 space-y-[3px] text-sm list-disc list-inside text-neutral-500 dark:text-neutral-400"
        >
          <li>Generative AI</li>
          <li>Web Development</li>
          <li>Computer Vision</li>
          <li>UI Design and Interactions</li>
        </ul>
        <br/>
        <p class="hero-handwritten mb-4 text-base text-neutral-600 dark:text-neutral-400">
            P.S: If it's more than 5 words, please talk to my AI assistant.
        </p>
        <div class="flex items-center gap-4 flex-wrap">
          <ChatButton />
          <Button text="📝 Resume" link="/ARKResume2026.pdf" />
          <div>
            <StatusIndicator status="offline" />  <!-- available statuses: online, offline, away, uni -->
          </div>
        </div>
      </div>

      <div
        class="relative flex justify-center w-full mt-10 md:mt-0 md:w-1/2 md:translate-y-4 xl:translate-y-0 order-first md:order-none"
      >
        <div
          class="relative flex items-center justify-center w-[280px] h-[280px] lg:w-[360px] lg:h-[360px] border-2 border-dashed rounded-full border-neutral-300 dark:border-neutral-700"
        >
          <img
            src="/assets/images/rajin-darkbg-tiny.png"
            class="w-[265px] h-[265px] lg:w-[335px] lg:h-[335px] rounded-full object-cover"
            alt="Rajin Khan - Senior Computer Science Student and AI Engineer"
            width="390"
            height="390"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>
  </div>

  <!-- Newsletter Section -->
  <Separator text="newsletter" />
  <div class="animate-in defer-render" style="--animation-delay: 150ms;">
    <Newsletter />
  </div>

  <!-- Animation applied to the separator -->
  <div class="animate-in" style="--animation-delay: 200ms;">
    <Separator text="My projects" />
  </div>

  <!-- Animation applied to the Projects section -->
  <div class="animate-in defer-render" style="--animation-delay: 400ms;">
    <Projects />
  </div>

  <Separator text="Tech Stack" />
  <div class="defer-render"><TechStack /></div>

  <Separator text="Latest Activity" />
  <div class="defer-render"><LatestCommit /></div>

  <Separator text="Oh, and I talk a lot" />
  <div class="defer-render"><Writings /></div>

  <Separator text="Guest Book" />
  <!-- A fixed modal cannot live inside content-visibility containment. -->
  <StickerBoard client:visible={{ rootMargin: "500px" }} />
</Layout>

<style>
  @font-face {
    font-family: "La Belle Aurore";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/assets/fonts/la-belle-aurore-latin.woff2") format("woff2");
  }

  .hero-handwritten {
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-weight: 400;
  }
</style>
