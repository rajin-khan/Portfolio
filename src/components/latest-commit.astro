<section class="latest-commit" aria-label="Latest GitHub activity">
  <a
    class="commit-slip"
    data-commit-card
    href="/github"
    aria-label="Open Rajin's GitHub activity"
  >
    <span class="commit-slip-shadow" aria-hidden="true"></span>
    <span class="commit-slip-panel">
      <span class="commit-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"
          ></path>
        </svg>
      </span>

      <span class="commit-copy">
        <span class="commit-byline">
          <span class="commit-author">@rajin-khan</span>
          <span> committed to </span>
          <strong data-commit-repo>GitHub</strong>
        </span>
        <span class="commit-message-row">
          <span class="commit-plus" aria-hidden="true">+</span>
          <span class="commit-message" data-commit-message>Loading latest commit...</span>
        </span>
      </span>

      <span class="commit-meta">
        <span class="commit-note" aria-hidden="true">still making things</span>
        <time data-commit-time datetime="">just now</time>
      </span>

      <span class="commit-arrow" aria-hidden="true">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </span>
    </span>
  </a>
</section>

<script is:inline>
  const GITHUB_USERNAME = "rajin-khan";
  const GITHUB_EVENTS_URL = `https://api.github.com/users/${GITHUB_USERNAME}/events/public?per_page=100&t=${Date.now()}`;
  const CACHE_KEY = "rajin-latest-commit";
  const CACHE_TTL = 15 * 60 * 1000;
  const API_HEADERS = {
    Accept: "application/vnd.github+json",
    "X-GitHub-Api-Version": "2022-11-28",
  };

  function formatTimeAgo(dateString) {
    const date = new Date(dateString);
    const difference = Math.max(0, Date.now() - date.getTime());
    const minutes = Math.floor(difference / (1000 * 60));
    if (minutes < 1) return "just now";
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    return `${Math.floor(hours / 24)}d ago`;
  }

  async function fetchLatestCommit() {
    try {
      const cached = sessionStorage.getItem(CACHE_KEY);
      if (cached) {
        const parsed = JSON.parse(cached);
        if (Date.now() - parsed.cachedAt < CACHE_TTL) return parsed.value;
      }
    } catch {
      // Strict privacy modes can deny storage; the live request still works.
    }

    const eventsResponse = await fetch(GITHUB_EVENTS_URL, {
      headers: API_HEADERS,
      cache: "no-store",
    });

    if (!eventsResponse.ok) {
      throw new Error(eventsResponse.status === 403 ? "rate-limit" : "events");
    }

    const events = await eventsResponse.json();
    const latestPush = Array.isArray(events)
      ? events.find((event) => event.type === "PushEvent" && event.payload?.head)
      : null;

    if (!latestPush) return null;

    const repository = latestPush.repo.name;
    const commitResponse = await fetch(
      `https://api.github.com/repos/${repository}/commits/${latestPush.payload.head}`,
      { headers: API_HEADERS, cache: "no-store" },
    );

    if (!commitResponse.ok) throw new Error("commit");
    const commit = await commitResponse.json();
    const value = {
      repository,
      message: commit.commit?.message || "No commit message",
      createdAt: latestPush.created_at,
    };

    try {
      sessionStorage.setItem(
        CACHE_KEY,
        JSON.stringify({ cachedAt: Date.now(), value }),
      );
    } catch {
      // The data is still usable when storage is unavailable.
    }

    return value;
  }

  async function updateLatestCommit() {
    const card = document.querySelector("[data-commit-card]");
    const repository = document.querySelector("[data-commit-repo]");
    const message = document.querySelector("[data-commit-message]");
    const time = document.querySelector("[data-commit-time]");
    if (!(card instanceof HTMLAnchorElement) || !repository || !message || !time) return;

    try {
      const latestCommit = await fetchLatestCommit();
      if (!latestCommit) {
        repository.textContent = "GitHub";
        message.textContent = "No recent public commits found.";
        time.textContent = "quietly building";
        return;
      }

      const shortMessage = latestCommit.message.split("\n")[0];
      repository.textContent = latestCommit.repository;
      message.textContent = shortMessage;
      message.setAttribute("title", shortMessage);
      time.textContent = formatTimeAgo(latestCommit.createdAt);
      time.setAttribute("datetime", latestCommit.createdAt);
      card.setAttribute(
        "aria-label",
        `${GITHUB_USERNAME} committed ${shortMessage} to ${latestCommit.repository}. Open GitHub activity.`,
      );
    } catch (error) {
      repository.textContent = "GitHub";
      message.textContent =
        error instanceof Error && error.message === "rate-limit"
          ? "Public activity is taking a breather."
          : "Commit feed unavailable. The archive still works.";
      time.textContent = "open archive";
    }
  }

  function initLatestCommit() {
    const card = document.querySelector("[data-commit-card]");
    if (!card) return;

    if (!("IntersectionObserver" in window)) {
      updateLatestCommit();
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return;
        observer.disconnect();
        updateLatestCommit();
      },
      { rootMargin: "400px" },
    );
    observer.observe(card);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLatestCommit, { once: true });
  } else {
    initLatestCommit();
  }
</script>

<style>
  @font-face {
    font-family: "La Belle Aurore";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/assets/fonts/la-belle-aurore-latin.woff2") format("woff2");
  }

  .latest-commit {
    width: 100%;
    max-width: 56rem;
    margin: 0 auto 3rem;
    padding: 4px calc(1.75rem + 6px) 8px;
    font-family: "Satoshi", ui-sans-serif, system-ui, sans-serif;
  }

  .commit-slip {
    position: relative;
    display: block;
    color: #e5e5e5;
    text-decoration: none;
  }

  .commit-slip-shadow,
  .commit-slip-panel {
    border: 1px dashed #4a4a4a;
    border-radius: 16px;
  }

  .commit-slip-shadow {
    position: absolute;
    inset: 0;
    background: transparent;
    transform: translate(3px, 3px);
    transition:
      border-color 220ms ease,
      transform 220ms ease;
  }

  .commit-slip-panel {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 0.9rem;
    min-height: 5.25rem;
    padding: 0.85rem 1rem;
    background: #0f0f0f;
    transition:
      background-color 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
  }

  .commit-slip:hover .commit-slip-panel {
    border-color: #696969;
    background: #151515;
    transform: translate(-2px, -2px);
  }

  .commit-slip:hover .commit-slip-shadow {
    border-color: #5d5d5d;
    transform: translate(4px, 4px);
  }

  .commit-slip:active .commit-slip-panel {
    transform: translate(0, 0) scale(0.995);
  }

  .commit-slip:focus-visible {
    outline: 2px solid #d4d4d4;
    outline-offset: 5px;
    border-radius: 16px;
  }

  .commit-mark {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    color: #a3a3a3;
    transition:
      color 220ms ease,
      transform 220ms ease;
  }

  .commit-mark svg {
    width: 1.35rem;
    height: 1.35rem;
  }

  .commit-slip:hover .commit-mark {
    color: #f5f5f5;
    transform: rotate(-4deg) scale(1.05);
  }

  .commit-copy {
    display: block;
    min-width: 0;
  }

  .commit-byline {
    display: block;
    overflow: hidden;
    color: #8e8e8e;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.25;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .commit-author,
  .commit-byline strong {
    color: #c9c9c9;
    font-weight: 700;
  }

  .commit-message-row {
    display: grid;
    grid-template-columns: 0.75rem minmax(0, 1fr);
    gap: 0.45rem;
    align-items: center;
    margin-top: 0.38rem;
  }

  .commit-plus,
  .commit-message {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .commit-plus {
    color: #a3a3a3;
    font-size: 0.86rem;
    font-weight: 700;
  }

  .commit-message {
    display: block;
    overflow: hidden;
    color: #ededed;
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .commit-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.62rem;
    min-width: 10.25rem;
  }

  .commit-meta time {
    color: #777;
    font-size: 0.66rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .commit-note {
    color: #b7b7b7;
    font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
    font-size: 0.98rem;
    font-weight: 400;
    line-height: 1;
    transform: rotate(-2deg);
  }

  .commit-arrow {
    display: grid;
    width: 1.65rem;
    height: 1.65rem;
    place-items: center;
    color: #777;
    transition:
      color 220ms ease,
      transform 220ms ease;
  }

  .commit-arrow svg {
    width: 1rem;
    height: 1rem;
  }

  .commit-slip:hover .commit-arrow {
    color: #f5f5f5;
    transform: translateX(2px);
  }

  @media (max-width: 640px) {
    .latest-commit {
      padding: 4px calc(1.25rem + 6px) 8px;
    }

    .commit-slip-panel {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.65rem;
      min-height: 5.75rem;
      padding: 0.78rem 0.85rem;
    }

    .commit-meta {
      grid-column: 2 / 4;
      grid-row: 2;
      justify-content: flex-end;
      width: 100%;
      min-width: 0;
      padding-top: 0.1rem;
    }

    .commit-arrow {
      grid-column: 3;
      grid-row: 1;
    }

    .commit-mark {
      width: 1.75rem;
      height: 1.75rem;
    }

    .commit-byline {
      font-size: 0.68rem;
    }

    .commit-message {
      font-size: 0.76rem;
    }

    .commit-note {
      font-size: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .commit-slip-shadow,
    .commit-slip-panel,
    .commit-mark,
    .commit-arrow {
      transition: none;
    }
  }
</style>
