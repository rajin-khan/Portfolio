---
import PageHeading from "../page-heading.astro";
import ProjectActions from "./project-actions.astro";
import type { ProjectDetailData } from "../../lib/projects";

interface Props {
  project: ProjectDetailData;
}

const { project } = Astro.props;
const projectStyle = `--project-accent-primary: ${project.accents.primary}; --project-accent-secondary: ${project.accents.secondary};`;
const statusClass = (status: string) => status.toLowerCase().replaceAll(" ", "-");
---

<section
  class="project-detail relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0"
  style={projectStyle}
>
  <div class="project-section fade-in">
    <PageHeading title={project.name} description={project.description} />

    <div class="my-4">
      <img
        src={project.image.src}
        alt={`${project.name} project preview`}
        class="project-banner glow-pulse"
        width={project.image.width}
        height={project.image.height}
        fetchpriority="high"
        decoding="async"
      />
    </div>

    {
      project.tags.length > 0 && (
        <div class="project-tags slide-in-up" style="animation-delay: 0.1s;">
          {project.tags.map((tag) => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>
      )
    }

    <ProjectActions actions={project.heroActions} />
  </div>

  {
    project.sections.map((section) => (
      <div class="project-section">
        <h2 class="project-section-heading slide-in-up">{section.title}</h2>

        {section.type === "prose" && (
          <>
            <div class="project-prose slide-in-up" style="animation-delay: 0.2s;">
              {section.paragraphs.map((paragraph) => <p set:html={paragraph} />)}
            </div>
            {section.actions && <ProjectActions actions={section.actions} delay="0.4s" />}
          </>
        )}

        {(section.type === "features" || section.type === "cards") && (
          <div class="project-card-grid">
            {section.items.map((item, index) => (
              <div
                class="project-card slide-in-up"
                style={`animation-delay: ${0.2 * (index + 1)}s;`}
              >
                <div class="project-card-heading">
                  {item.icon && <span class="project-card-icon" aria-hidden="true">{item.icon}</span>}
                  <h3>{item.name}</h3>
                </div>
                <p>{item.description}</p>
              </div>
            ))}
          </div>
        )}

        {section.type === "use-cases" && (
          <div class="project-card-grid">
            {section.items.map((item, index) => (
              <div
                class="project-card project-use-case slide-in-up"
                style={`animation-delay: ${0.2 * (index + 1)}s;`}
              >
                {item.emoji && <span class="project-card-icon" aria-hidden="true">{item.emoji}</span>}
                <div>
                  <h3>{item.name}</h3>
                  <p>{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        )}

        {section.type === "roadmap" && (
          <div class="project-card-grid">
            {section.items.map((item, index) => (
              <div
                class:list={["project-card", "project-roadmap-card", "slide-in-up", statusClass(item.status)]}
                style={`animation-delay: ${0.2 * (index + 1)}s;`}
              >
                <span class="project-status">{item.status}</span>
                <h3>{item.name}</h3>
              </div>
            ))}
          </div>
        )}

        {section.type === "team" && (
          <div class="project-card-grid">
            {section.items.map((member, index) => (
              <div
                class="project-card project-team-card slide-in-up"
                style={`animation-delay: ${0.2 * (index + 1)}s;`}
              >
                <h3>{member.name}</h3>
                <p>{member.institution}</p>
                <a href={member.github} target="_blank" rel="noopener noreferrer">
                  View GitHub
                </a>
              </div>
            ))}
          </div>
        )}
      </div>
    ))
  }
</section>

<style>
  @keyframes project-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes project-slide-in-up {
    from {
      opacity: 0;
      transform: translate3d(0, 20px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes project-glow-pulse {
    0%,
    100% {
      box-shadow:
        0 0 5px color-mix(in srgb, var(--project-accent-primary) 30%, transparent),
        0 0 10px color-mix(in srgb, var(--project-accent-secondary) 30%, transparent);
    }
    50% {
      box-shadow:
        0 0 15px color-mix(in srgb, var(--project-accent-primary) 60%, transparent),
        0 0 20px color-mix(in srgb, var(--project-accent-secondary) 60%, transparent);
    }
  }

  .project-section {
    margin-bottom: 2.5rem;
  }

  .fade-in {
    animation: project-fade-in 0.8s ease-in-out both;
  }

  .slide-in-up {
    animation: project-slide-in-up 0.6s ease-out both;
  }

  .glow-pulse {
    animation: project-glow-pulse 2s ease-in-out infinite;
  }

  .project-banner {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border: 2px solid transparent;
    border-radius: 1rem;
    padding: 4px;
    background: linear-gradient(
      45deg,
      var(--project-accent-primary),
      var(--project-accent-secondary)
    );
    transition: transform 0.3s ease;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1rem;
  }

  .project-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.375rem;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 0.35rem;
    color: rgb(245 245 245 / 0.9);
    background: rgb(64 64 64 / 0.55);
    font-size: 0.65rem;
    font-weight: 500;
    line-height: 1;
  }

  .project-section-heading {
    position: relative;
    margin-bottom: 1.5rem;
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .project-section-heading::after {
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 50px;
    height: 2px;
    border-radius: 1px;
    background: linear-gradient(
      to right,
      var(--project-accent-primary),
      var(--project-accent-secondary)
    );
    content: "";
  }

  .project-prose p {
    margin-bottom: 1rem;
    color: #d4d4d8;
  }

  .project-prose :global(strong),
  .project-prose :global(em),
  .project-prose :global(code) {
    color: #fff;
  }

  .project-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .project-card {
    min-width: 0;
    padding: 1rem;
    border: 1px solid
      color-mix(in srgb, var(--project-accent-primary) 22%, transparent);
    border-radius: 0.75rem;
    background: rgb(31 41 55 / 0.3);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      background-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .project-card-heading {
    display: flex;
    align-items: center;
  }

  .project-use-case {
    display: flex;
    align-items: flex-start;
  }

  .project-card-icon {
    flex: 0 0 auto;
    margin-right: 0.75rem;
    color: var(--project-accent-primary);
    font-size: 1.5rem;
    line-height: 1.25;
  }

  .project-card h3 {
    margin-bottom: 0.25rem;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .project-card p {
    color: #d4d4d8;
    font-size: 0.875rem;
  }

  .project-status {
    display: inline-block;
    margin-bottom: 0.5rem;
    padding: 0.25rem 0.5rem;
    border-radius: 1rem;
    color: var(--project-accent-primary);
    background: color-mix(
      in srgb,
      var(--project-accent-primary) 12%,
      transparent
    );
    font-size: 0.75rem;
    font-weight: 500;
  }

  .project-roadmap-card.in-progress .project-status {
    color: var(--project-accent-secondary);
    background: color-mix(
      in srgb,
      var(--project-accent-secondary) 12%,
      transparent
    );
  }

  .project-team-card a {
    color: color-mix(in srgb, var(--project-accent-primary) 80%, white);
    font-size: 0.875rem;
  }

  .project-team-card a:hover {
    text-decoration: underline;
  }

  @media (hover: hover) {
    .project-banner:hover {
      transform: scale(1.02);
    }

    .project-card:hover {
      transform: translateY(-5px);
      border-color: color-mix(
        in srgb,
        var(--project-accent-primary) 55%,
        transparent
      );
      background: rgb(55 65 81 / 0.5);
      box-shadow: 0 5px 15px
        color-mix(in srgb, var(--project-accent-primary) 30%, transparent);
    }
  }

  @media (min-width: 640px) {
    .project-section-heading {
      font-size: 1.75rem;
    }

    .project-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-in,
    .slide-in-up,
    .glow-pulse {
      animation: none;
    }

    .project-banner,
    .project-card {
      transition: none;
    }
  }
</style>
