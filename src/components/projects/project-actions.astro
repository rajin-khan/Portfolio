---
import type { ProjectDetailData } from "../../lib/projects";

interface Props {
	actions: ProjectDetailData["heroActions"];
	delay?: string;
}

const { actions, delay = "0.2s" } = Astro.props;
---

<div class="project-actions" style={`--project-action-delay: ${delay};`}>
  {
    actions.map((action) => (
      <a
        href={action.href}
        target="_blank"
        rel="noopener noreferrer"
        class:list={["project-action", { "project-action-primary": action.primary }]}
      >
        {action.label}
      </a>
    ))
  }
</div>

<style>
  @keyframes project-actions-enter {
    from {
      opacity: 0;
      transform: translate3d(0, 20px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes project-action-glow {
    0%,
    100% {
      box-shadow:
        0 0 5px color-mix(in srgb, var(--project-accent-primary) 30%, transparent),
        0 0 10px color-mix(in srgb, var(--project-accent-secondary) 30%, transparent);
    }
    50% {
      box-shadow:
        0 0 15px color-mix(in srgb, var(--project-accent-primary) 60%, transparent),
        0 0 20px color-mix(in srgb, var(--project-accent-secondary) 60%, transparent);
    }
  }

  .project-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.5rem 0;
    animation: project-actions-enter 0.6s ease-out var(--project-action-delay) both;
  }

  .project-action {
    display: inline-block;
    padding: 0.375rem 1rem;
    border: 1px solid #404040;
    border-radius: 9999px;
    color: #e5e5e5;
    background: transparent;
    font-size: 0.875rem;
    font-weight: 600;
    transition:
      color 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease;
  }

  .project-action:hover {
    color: #171717;
    background: #e5e5e5;
  }

  .project-action-primary {
    color: #171717;
    background: #e5e5e5;
    animation: project-action-glow 2s ease-in-out infinite;
  }

  .project-action-primary:hover {
    color: #f5f5f5;
    background: #171717;
  }

  @media (min-width: 640px) {
    .project-actions {
      flex-direction: row;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-actions,
    .project-action-primary {
      animation: none;
    }
  }
</style>
