---

const iconPath = (asset: string) =>
  `/assets/icons/tech/${asset.includes(".") ? asset : `${asset}.svg`}`;

const techStackItems = [
  { name: "Git", asset: "git" },
  { name: "Railway", asset: "railway", adaptive: true },
  { name: "Vercel", asset: "vercel", adaptive: true },
  { name: "Next.js", asset: "nextjs", adaptive: true },
  { name: "Vite", asset: "vite" },
  { name: "Astro", asset: "astro-dark" },
  { name: "React", asset: "react" },
  { name: "Tailwind CSS", asset: "tailwind-css" },
  { name: "Stripe", asset: "stripe" },
  { name: "Lemon Squeezy", asset: "lemon-squeezy" },
  { name: "Paddle", asset: "paddle" },
  { name: "AWS", asset: "aws-dark" },
  { name: "Mintlify", asset: "mintlify" },
  { name: "Supabase", asset: "supabase" },
  { name: "WordPress", asset: "wordpress" },
  { name: "Codex", asset: "codex-dark.png" },
  { name: "Cursor", asset: "cursor-dark" },
  { name: "Groq", asset: "groq.webp" },
  { name: "Ollama", asset: "ollama", adaptive: true },
  { name: "MySQL", asset: "mysql" },
  { name: "ChromaDB", asset: "chromadb" },
  { name: "Flutter", asset: "flutter" },
  { name: "FastAPI", asset: "fastapi" },
  { name: "NumPy", asset: "numpy" },
  { name: "Pandas", asset: "pandas-dark" },
  { name: "Matplotlib", asset: "matplotlib" },
  { name: "Seaborn", asset: "seaborn" },
  { name: "PyTorch", asset: "pytorch" },
  { name: "YOLO", asset: "yolo" },
  { name: "OpenCV", asset: "opencv" },
  { name: "Jupyter", asset: "jupyter-dark" },
  { name: "C", asset: "c" },
  { name: "C++", asset: "cplusplus" },
  { name: "Java", asset: "java" },
  { name: "Python", asset: "python" },
  { name: "Dart", asset: "dart" },
  { name: "PHP", asset: "php" },
  { name: "SQL", asset: "sql", adaptive: true },
  { name: "Bash", asset: "bash", adaptive: true },
  { name: "HTML", asset: "html" },
  { name: "CSS", asset: "css" },
];

const duplicatedTechStack = [
  ...techStackItems.map((tech) => ({ ...tech, duplicate: false })),
  ...techStackItems.map((tech) => ({ ...tech, duplicate: true })),
];
const animationDuration = techStackItems.length * 3;
---

<section class="w-full py-0 md:py-0">
  <div class="scroller-container mx-auto max-w-5xl" data-animated="true">
    <div class="scroller-inner">
      {duplicatedTechStack.map((tech) => (
        <div class="tech-item" aria-hidden={tech.duplicate ? "true" : undefined}>
          <img
            src={iconPath(tech.asset)}
            alt={tech.duplicate ? "" : tech.name}
            class:list={[
              "tech-logo",
              { "tech-logo--adaptive": tech.adaptive },
            ]}
            width="40"
            height="40"
            loading="eager"
            fetchpriority="low"
            decoding="async"
            draggable="false"
          />
          <span class="tech-name">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
  
<style define:vars={{ animationDuration: `${animationDuration}s` }}>
  .scroller-container {
    position: relative;
    block-size: 2.5rem;
    max-width: 100%;
    overflow: clip;
    overflow-clip-margin: 0;
    contain: layout paint;
    -webkit-mask: linear-gradient(90deg, transparent, white 10%, white 90%, transparent);
            mask: linear-gradient(90deg, transparent, white 10%, white 90%, transparent);
  }
  
  .scroller-inner {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    width: max-content;
    animation: scroll var(--animationDuration) linear infinite;
  }

  @media (min-width: 768px) {
    .scroller-container {
      block-size: 3rem;
    }
  }
  
  .tech-item {
    @apply flex items-center gap-x-4 whitespace-nowrap px-6 py-0;
    @apply transition-transform duration-200 ease-in-out;
  }
  
  .tech-item:hover {
    transform: scale(1.1);
  }
  
  .tech-logo {
    @apply h-8 w-8 flex-shrink-0 object-contain md:h-10 md:w-10;
    filter:
      drop-shadow(0 1px 2px rgb(0 0 0 / 0.15))
      drop-shadow(0 0 1px rgb(0 0 0 / 0.2));
  }
  
  :global(html.dark) .tech-logo--adaptive {
    filter:
      brightness(0)
      invert(1)
      drop-shadow(0 1px 2px rgb(0 0 0 / 0.15))
      drop-shadow(0 0 1px rgb(0 0 0 / 0.2));
  }

  .tech-name {
    @apply text-base font-bold text-neutral-800 dark:text-neutral-200 md:text-lg;
  }
  
  .scroller-container:hover .scroller-inner {
    animation-play-state: paused;
  }
  
  @keyframes scroll {
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroller-inner {
      animation: none;
    }
  }
</style>
