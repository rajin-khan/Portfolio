---
import type { ProjectData } from "../lib/projects";

interface Props {
	project: ProjectData;
}

const { project } = Astro.props;
const isExternal = project.href.startsWith("http");
---

<a
	href={project.href}
	target={isExternal ? "_blank" : undefined}
	rel={isExternal ? "noopener noreferrer" : undefined}
	class="project-card"
	style={`--project-screen: ${project.accents.screen}; --project-accent: ${project.accents.primary};`}
>
	<article class="project-card-inner">
		<div class="project-card-art">
			<img
				src={project.image.src}
				alt={`${project.cardName} project preview`}
				width={project.image.width}
				height={project.image.height}
				loading="lazy"
				decoding="async"
			/>
		</div>

		<div class="project-card-copy">
			<div class="project-card-heading">
				<h3>{project.cardName}</h3>
				<span class="project-card-arrow" aria-hidden="true">↗</span>
			</div>
			<p class="project-card-note">{project.note}</p>
			<p class="project-card-description">{project.cardDescription}</p>
			<div class="project-card-tags" aria-label={`${project.cardName} tags`}>
				{project.tags.map(tag => <span>{tag}</span>)}
			</div>
		</div>
	</article>
</a>

<style>
	.project-card {
		position: relative;
		display: block;
		height: 100%;
		padding: 0;
		color: inherit;
		isolation: isolate;
		text-decoration: none;
	}

	.project-card::before {
		position: absolute;
		inset: 0;
		z-index: 0;
		border: 1px dashed rgba(255, 255, 255, 0.17);
		border-radius: 8px;
		background: transparent;
		content: "";
		pointer-events: none;
		transition:
			border-color 160ms ease,
			transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.project-card:hover::before,
	.project-card:focus-visible::before {
		border-color: rgba(255, 255, 255, 0.27);
		transform: translate3d(3px, 3px, 0);
	}

	.project-card:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.5);
		outline-offset: 4px;
	}

	.project-card-inner {
		position: relative;
		z-index: 1;
		display: flex;
		height: 100%;
		min-width: 0;
		margin: 0;
		padding: 14px;
		flex-direction: column;
		border: 1px solid rgba(255, 255, 255, 0.085);
		border-radius: 8px;
		background: #0d0d0d;
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.16);
		backface-visibility: hidden;
		transition:
			border-color 160ms ease,
			transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.project-card:hover .project-card-inner,
	.project-card:focus-visible .project-card-inner {
		border-color: rgba(255, 255, 255, 0.15);
		transform: translate3d(-3px, -3px, 0);
	}

	.project-card-art {
		position: relative;
		display: block;
		width: 100%;
		overflow: hidden;
		border-radius: 5px;
		background: var(--project-screen);
		aspect-ratio: 16 / 9;
		isolation: isolate;
	}

	.project-card-art::after {
		position: absolute;
		inset: 0;
		z-index: 1;
		background: #000;
		content: "";
		opacity: 0.08;
		pointer-events: none;
		transition: opacity 180ms ease;
	}

	.project-card-art img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		backface-visibility: hidden;
		transform: translateZ(0) scale(1.001);
		transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.project-card:hover .project-card-art::after,
	.project-card:focus-visible .project-card-art::after {
		opacity: 0.01;
	}

	.project-card:hover .project-card-art img,
	.project-card:focus-visible .project-card-art img {
		transform: translateZ(0) scale(1.012);
	}

	.project-card-copy {
		display: flex;
		min-height: 140px;
		padding: 17px 7px 9px;
		flex: 1;
		flex-direction: column;
	}

	.project-card-heading {
		display: flex;
		min-width: 0;
		align-items: center;
		gap: 8px;
	}

	.project-card-heading h3 {
		min-width: 0;
		margin: 0;
		color: #efefeb;
		font-size: 1.18rem;
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1.12;
		overflow-wrap: anywhere;
	}

	.project-card-arrow {
		flex: 0 0 auto;
		color: #d8d8d3;
		font-size: 0.68rem;
		opacity: 0.52;
		transform: translate(-2px, 2px);
		transition:
			opacity 180ms ease,
			transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
	}

	.project-card:hover .project-card-arrow,
	.project-card:focus-visible .project-card-arrow {
		opacity: 1;
		transform: translate(1px, -1px);
	}

	.project-card-note {
		margin: 8px 0 0 1px;
		color: #d8d8d3;
		font-family: "La Belle Aurore", "Bradley Hand", "Segoe Print", cursive;
		font-size: 0.96rem;
		line-height: 1.28;
		transform: rotate(-0.7deg);
		transform-origin: left center;
	}

	.project-card-description {
		margin: 10px 0 0;
		color: #969692;
		font-size: 0.76rem;
		font-weight: 500;
		line-height: 1.5;
		text-wrap: pretty;
	}

	.project-card-tags {
		display: flex;
		margin-top: auto;
		padding-top: 17px;
		flex-wrap: wrap;
		gap: 6px 0;
	}

	.project-card-tags > span {
		display: inline-flex;
		align-items: center;
		color: #858581;
		font-size: 0.57rem;
		font-weight: 600;
		line-height: 1;
		transition: color 180ms ease;
	}

	.project-card-tags > span:not(:last-child)::after {
		margin-inline: 7px;
		color: #50504d;
		content: "/";
		font-weight: 500;
	}

	.project-card:hover .project-card-tags > span,
	.project-card:focus-visible .project-card-tags > span {
		color: #a3a39f;
	}

	@media (max-width: 520px) {
		.project-card-copy {
			min-height: 138px;
		}

		.project-card-note {
			font-size: 0.94rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.project-card,
		.project-card::before,
		.project-card-inner,
		.project-card-art::after,
		.project-card-art img,
		.project-card-arrow,
		.project-card-tags > span {
			transition: none !important;
		}
	}
</style>
